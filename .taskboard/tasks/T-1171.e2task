  "executionContract": {
    "taskType": "Упрощение primary-действия создания задачи в VS Code Task Board",
    "readyToStart": [
      "T-1171 находится во внутренней проверке без зависимостей и блокеров; текущее уточнение пользователя разрешает вернуть её в работу.",
      "Текущая split-секция содержит только дублирующие действия создания и обновления.",
      "Изменение начинается с актуализации доменного документа и наблюдаемого RED regression."
    ],
    "stopConditions": [
      "Основная кнопка не сможет открывать существующий поток создания задачи без вторичного меню.",
      "Удаление split-кода потребует изменить lifecycle, CLI mutation или модальную форму создания задачи.",
      "Нельзя сохранить клавиатурную и мышиную доступность основной кнопки."
    ],
    "allowedChanges": [
      "HTML, TypeScript и CSS верхней панели VS Code Task Board.",
      "Focused regression контракта единственной кнопки создания.",
      "Доменный документ, generated documentation index, canonical T-1171 и append-only дневник.",
      "path:docs/editor/project-tasks-board.md",
      "path:src/Electron2D.VsCode/src/webview.css",
      "path:src/Electron2D.VsCode/src/webview.ts",
      "path:src/Electron2D.VsCode/src/webviewHtml.ts",

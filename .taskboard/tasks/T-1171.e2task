      "payload": {
        "sourceKind": "TaskPatchedV3Draft",
        "text": "{\"patch\":[{\"op\":\"replace\",\"path\":\"/title\",\"value\":\"\\u0423\\u0431\\u0440\\u0430\\u0442\\u044C \\u0441\\u0442\\u0440\\u0435\\u043B\\u043A\\u0443 \\u0438\\u0437 \\u043A\\u043D\\u043E\\u043F\\u043A\\u0438 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u044F \\u0437\\u0430\\u0434\\u0430\\u0447\\u0438\"},{\"op\":\"replace\",\"path\":\"/description\",\"value\":\"\\u0412 \\u0432\\u0435\\u0440\\u0445\\u043D\\u0435\\u0439 \\u043F\\u0430\\u043D\\u0435\\u043B\\u0438 \\u0434\\u043E\\u0441\\u043A\\u0438 \\u0434\\u043E\\u043B\\u0436\\u043D\\u0430 \\u043E\\u0441\\u0442\\u0430\\u0442\\u044C\\u0441\\u044F \\u043E\\u0434\\u043D\\u0430 \\u043E\\u0431\\u044B\\u0447\\u043D\\u0430\\u044F primary-\\u043A\\u043D\\u043E\\u043F\\u043A\\u0430 \\u0060\\u0421\\u043E\\u0437\\u0434\\u0430\\u0442\\u044C \\u0437\\u0430\\u0434\\u0430\\u0447\\u0443\\u0060 \\u0431\\u0435\\u0437 \\u043F\\u0440\\u0430\\u0432\\u043E\\u0439 split-\\u0441\\u0435\\u043A\\u0446\\u0438\\u0438 \\u0438 \\u0441\\u0442\\u0440\\u0435\\u043B\\u043A\\u0438. \\u0412\\u044B\\u043F\\u0430\\u0434\\u0430\\u044E\\u0449\\u0435\\u0435 \\u043C\\u0435\\u043D\\u044E \\u0441 \\u0434\\u0443\\u0431\\u043B\\u0438\\u0440\\u0443\\u044E\\u0449\\u0438\\u043C\\u0438 \\u0434\\u0435\\u0439\\u0441\\u0442\\u0432\\u0438\\u044F\\u043C\\u0438 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u044F \\u0438 \\u043E\\u0431\\u043D\\u043E\\u0432\\u043B\\u0435\\u043D\\u0438\\u044F \\u0431\\u043E\\u043B\\u044C\\u0448\\u0435 \\u043D\\u0435 \\u043D\\u0443\\u0436\\u043D\\u043E: \\u043E\\u0441\\u043D\\u043E\\u0432\\u043D\\u0430\\u044F \\u043A\\u043D\\u043E\\u043F\\u043A\\u0430 \\u043F\\u043E-\\u043F\\u0440\\u0435\\u0436\\u043D\\u0435\\u043C\\u0443 \\u043E\\u0442\\u043A\\u0440\\u044B\\u0432\\u0430\\u0435\\u0442 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u0435 \\u0437\\u0430\\u0434\\u0430\\u0447\\u0438, \\u0430 \\u043E\\u0442\\u0434\\u0435\\u043B\\u044C\\u043D\\u0430\\u044F SVG-\\u043A\\u043D\\u043E\\u043F\\u043A\\u0430 \\u043E\\
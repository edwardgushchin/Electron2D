{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-e34c978412224413be0767de3bdf17cf",
  "revision": 30,
  "taskId": "T-1235",
  "legacyAliases": [],
  "title": "Поддержать конкурентную запись Task Board из нескольких агентов",
  "description": "Task Board и e2d tasks должны безопасно принимать одновременные команды нескольких независимых агентов и процессов. Текущий fail-fast global writer lock регулярно завершает нормальные операции ошибкой E2D-CLI-0002 вместо ограниченного ожидания и безопасной сериализации. Требуется многопроцессная координация с атомарной перезагрузкой состояния после получения lock, optimistic CAS для содержательных конфликтов, идемпотентным повтором transient-сбоев и централизованным sequence для append-only conversation/activity/checkpoints. Независимые изменения и параллельное создание должны сохраняться без потерь и дубликатов; конфликтующие изменения одной revision должны завершаться явным CAS conflict, а не last-write-wins. T-1178 остаётся клиентской защитой VS Code, эта задача устанавливает общие гарантии самого store и CLI.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P0",
  "tagIds": [
    "tag-0001",
    "tag-0008",
    "tag-0009",
    "tag-0011",
    "tag-0018",
    "tag-0026"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [
    {
      "relationId": "relation-vscode-writer-retry",
      "kind": "RelatedTo",
      "targetTaskUid": "task-9f8df07699d948d285cdaa7fc75657d2"
    }
  ],
  "acceptanceCriteria": [
    {
      "criterionId": "criterion-concurrency-contract",
      "description": "До изменения production-кода доменные документы нормативно определяют модель нескольких writer-процессов, границы транзакции, правила CAS/rebase, идемпотентность, порядок append-операций, таймауты, отмену и восстановление после сбоя.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "criterion-independent-writes",
      "description": "Одновременные CLI-мутации независимых задач из нескольких процессов или агентов сериализуются с ограниченным ожиданием и завершаются без fail-fast ошибки `E2D-CLI-0002: Taskboard is locked by another writer`; все подтверждённые изменения сохраняются.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs"
        }
      ]
    },
    {
      "criterionId": "criterion-concurrent-create",
      "description": "Параллельное создание задач безопасно распределяет уникальные `taskId`/`taskUid`, не требует от клиента угадывать актуальную board revision после ожидания writer lock и не создаёт дубликатов при повторе одной операции.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs"
        }
      ]
    },
    {
      "criterionId": "criterion-same-task-cas",
      "description": "Конкурирующие изменения одной задачи либо безопасно объединяются только для явно коммутативных операций, либо возвращают детерминированный revision/CAS conflict с актуальной revision; last-write-wins и потеря уже записанного контекста запрещены.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Mutations.cs"
        }
      ]
    },
    {
      "criterionId": "criterion-atomic-append",
      "description": "Одновременные добавления сообщений, activity и checkpoints назначают sequence централизованно и атомарно: идентификаторы и sequence уникальны, sequence непрерывна, ответы не теряются и append-only элементы не переписываются.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs"
        }
      ]
    },
    {
      "criterionId": "criterion-lock-lifecycle",
      "description": "Writer coordination имеет ограниченный настраиваемый timeout, backoff, отмену и понятную retryable-диагностику; зависший или аварийно завершившийся процесс не оставляет вечную блокировку, а multi-file transaction остаётся атомарной и восстанавливаемой.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.ProjectSystem/Tasks/TaskBoardDiskStore.cs"
        }
      ]
    },
    {
      "criterionId": "criterion-idempotent-cli",
      "description": "CLI предоставляет стабильный operation/idempotency identity для безопасного повтора transient-сбоев и возвращает машинно-читаемую причину конфликта; повтор не дублирует задачу, сообщение, activity, связь, вложение или смену статуса.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.Cli/ProjectTasksCli.cs"
        }
      ]
    },
    {
      "criterionId": "criterion-concurrency-tests",
      "description": "RED/GREEN многопроцессные integration/stress tests многократно покрывают разные задачи, одну задачу, параллельное создание, conversation append, timeout/cancellation и аварийное восстановление; затем проходят focused tests, `e2d tasks verify`, docs verifier и `git diff --check`.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs"
        }
      ]
    }
  ],

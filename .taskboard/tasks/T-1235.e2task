  "executionContract": {
    "taskType": "многопроцессная конкурентная запись Agent-native Task Board через CLI",
    "readyToStart": [
      "Ошибка `E2D-CLI-0002: Taskboard is locked by another writer` воспроизводится при пересечении команд нескольких агентов.",
      "До production-кода синхронизированы `docs/project-system/project-task-manager.md` и `docs/cli/e2d-cli.md`, затем добавлены падающие многопроцессные тесты.",
      "Область отделена от T-1178: T-1178 отвечает за очередь клиента VS Code, эта задача — за гарантии общего Task Board store и CLI для независимых writer-процессов."
    ],
    "stopConditions": [
      "Реализация требует ослабить optimistic CAS, append-only conversation/activity/checkpoints, identity trust или semantic/transition validation.",
      "Предлагается last-write-wins, прямое редактирование `.taskboard`, неатомарная запись board/task-файлов либо бесконечное скрытое ожидание lock.",
      "Нельзя обеспечить идемпотентный повтор команды без риска дублирования внешне наблюдаемой мутации.",
      "Изменение формата становится обратно несовместимым без отдельной версии schema и детерминированной миграции."
    ],
    "allowedChanges": [
      "Доменные контракты Task Board/CLI, writer coordination и transaction storage в `Electron2D.ProjectSystem`, публичная CLI-команда и структурированные diagnostics.",
      "Focused unit/integration/multi-process tests, verifier fixtures и минимальные изменения потребителей, необходимые для operation identity и retryable diagnostics.",
      "Generated docs index, task activity и append-only дневник после синхронизации поведения.",
      "path:docs/cli/e2d-cli.md",
      "path:docs/project-system/project-task-manager.md",
      "path:src/Electron2D.Cli/ProjectTasksCli.cs",
      "path:src/Electron2D.ProjectSystem/Tasks/TaskBoardV3DiskStore.cs",
      "path:src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Mutations.cs",
      "path:src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Validation.cs",
      "path:tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs",
      "path:tests/Electron2D.Tests.Integration/ProjectTaskManagerTests.cs",
      "path:tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs",
      "path:data/dev-diary/**",
      "path:src/Electron2D.VsCode/.vscode-test/user-data/**",
      "path:src/Electron2D.VsCode/dist/**",
      "path:src/Electron2D.VsCode/src/cli.ts",
      "path:src/Electron2D.VsCode/src/extension.ts",
      "path:src/Electron2D.VsCode/src/localization.ts",
      "path:src/Electron2D.VsCode/test/unit/cli.test.ts",
      "path:src/Electron2D.VsCode/test/suite/index.ts",
      "path:src/Electron2D.VsCode/artifacts/**",
      "path:data/documentation/**",
      "path:docs/editor/project-tasks-board.md"
    ],
    "forbiddenChanges": [
      "Ручное редактирование `.taskboard`, отключение CAS/validation, перезапись или удаление прежних сообщений/activity/checkpoints и потеря concurrent update.",
      "Глобальный бесконечный mutex, lock без timeout/cancellation/recovery, неограниченный retry либо повтор semantic/revision конфликтов как transient.",
      "Несвязанный рефакторинг UI Task Board и повторная реализация FIFO-очереди VS Code из T-1178.",
      "Автоматическая приёмка или архивация этой и других задач."
    ],
    "requiredOutputs": [
      "Воспроизводимый и документированный multi-writer contract Task Board/CLI с явной классификацией transient и semantic/CAS конфликтов.",
      "Атомарная writer coordination с ограниченным ожиданием, безопасным повтором, idempotency identity и crash recovery.",
      "Многопроцессные RED/GREEN tests без потерянных updates, дубликатов ID/операций и повреждения `.taskboard`.",
      "Синхронизированные доменные документы, CLI help/diagnostics и доказательства focused verification."
    ],
    "commands": [
      {
        "commandId": "cmd-concurrency-contract-tests",
        "kind": "Process",
        "executable": "dotnet",
        "arguments": [
          "test",

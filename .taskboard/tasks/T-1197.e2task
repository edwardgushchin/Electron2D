{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-cde6abab1bcd4277835f62768c8dbe20",
  "revision": 34,
  "taskId": "T-1197",
  "legacyAliases": [],
  "title": "Добавить теги, дедлайн и показатели на карточки",
  "description": "Дополнить карточки задач полезными необязательными данными. Теги принадлежат всей доске, а задача хранит только ссылки на них. При выборе можно использовать существующий тег либо создать новый: новый тег сначала добавляется в общий каталог доски, затем назначается задаче и становится доступен всем остальным задачам. Каталогом также можно управлять вручную в настройках доски. Если у задачи задан дедлайн, карточка показывает дату. Если есть критерии приёмки, карточка показывает прогресс как чеклист. Если есть прикреплённые файлы, карточка показывает их количество; связанные пути к файлам в этот счётчик не входят. Обновить схемы, CLI, компактный снимок, VS Code UI, тесты и документацию, затем проверить установленное расширение на реальной доске.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P0",
  "tagIds": [
    "tag-0001",
    "tag-0009"
  ],
  "deadline": "2026-07-20",
  "createdBy": "cli",
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "board-tag-catalog",
      "description": "Доска хранит общий каталог тегов с устойчивыми идентификаторами, названиями и цветами; другие изменения доски не теряют этот каталог.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "compact-card-data",
      "description": "Компактный снимок содержит определения и ссылки тегов, дедлайн, количество выполненных и всех критериев, а также число прикреплённых файлов без учёта связанных путей.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "optional-deadline",
      "description": "Задача поддерживает необязательный дедлайн, который можно задать и очистить через CLI без ручного редактирования файла.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "tag-cli",
      "description": "CLI позволяет создавать, изменять и безопасно удалять теги, назначать существующий тег задаче и атомарно создать глобальный тег с назначением задаче.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs"
        }
      ]
    },
    {
      "criterionId": "task-tag-references",
      "description": "Задача хранит только ссылки на глобальные теги. Проверка доски отклоняет отсутствующие ссылки, а удаление используемого тега не оставляет повреждённые задачи.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "verified-real-ui",
      "description": "Схемы, focused и regression tests, документация, VSIX и реальный VS Code подтверждают новый контракт и отсутствие лишних показателей у пустой карточки.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "vscode-settings-and-card",
      "description": "Настройки доски позволяют управлять глобальными тегами, редактирование задачи — выбирать их или создать глобальный тег, а карточка показывает только имеющиеся теги, дедлайн, прогресс чеклиста и число вложений.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    }
  ],

  "executionContract": {
    "taskType": "модальное представление сведений о задаче в VS Code Task Board",
    "readyToStart": [
      "Боковая панель сведений занимает отдельную полосу и уменьшает доступную ширину доски; целевое поведение — центрированное модальное окно поверх доски.",
      "Действия задачи и revision-aware граница записи через TaskBoard CLI уже существуют и должны быть сохранены."
    ],
    "stopConditions": [
      "Для модального представления требуется изменить lifecycle задач, формат TaskBoard, команды CLI или доверенную границу Extension Host.",
      "Нельзя сохранить доступное закрытие, возврат фокуса или существующие действия задачи без расширения согласованного объёма."
    ],
    "allowedChanges": [
      "Доменный документ VS Code Task Board, разметка и стили окна сведений, связанные unit/layout и Extension Host tests.",
      "Сборка и установка VSIX, визуальная проверка реального окна VS Code, activity задачи и append-only дневник."
    ],
    "forbiddenChanges": [
      "Изменение lifecycle, статусов, revision-aware мутаций, формата TaskBoard или команд `e2d tasks`.",
      "Ручное редактирование `.taskboard`, несвязанный рефакторинг карточек или колонок и отключение доступности модального окна."
    ],
    "requiredOutputs": [
      "Центрированное модальное окно с backdrop, ограниченной геометрией и независимой прокруткой содержимого без изменения ширины доски.",
      "Доступное закрытие кнопкой, Escape и щелчком по фону с возвратом фокуса на исходную карточку.",
      "Сохранённые действия задачи, регрессионные проверки, собранный VSIX и визуальное доказательство из реального VS Code либо явно зафиксированный остаточный риск."
    ],

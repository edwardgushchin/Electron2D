  "acceptanceCriteria": [
    {
      "criterionId": "criterion-001",
      "description": "Все задачи ROADMAP §2 закрыты либо имеют утверждённый контракт `Deferred` или `Unsupported` через manual public API profile.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-002",
      "description": "Machine-readable fields зафиксированы: `Execution class: final-gate`, `Agent action: verify-only-unless-gate-tooling-evidence-is-missing`, `Forbidden: fixing-leaf-class-implementation-or-subsystem-backend-inside-this-task` и `Output` со ссылками на gate report artifacts.",
      "state": "Open",
      "evidence": []
    },

        "sourceKind": "TaskPatchedV3Draft",
        "text": "{\"patch\":[{\"op\":\"replace\",\"path\":\"/description\",\"value\":\"VS Code Task Board \\u0434\\u043E\\u043B\\u0436\\u043D\\u0430 \\u043F\\u043E\\u043A\\u0430\\u0437\\u044B\\u0432\\u0430\\u0442\\u044C \\u043F\\u043E-\\u0440\\u0443\\u0441\\u0441\\u043A\\u0438 \\u0432\\u0441\\u0435 \\u0448\\u0435\\u0441\\u0442\\u044C \\u0430\\u043A\\u0442\\u0443\\u0430\\u043B\\u044C\\u043D\\u044B\\u0445 \\u043A\\u043E\\u043B\\u043E\\u043D\\u043E\\u043A: \\u00AB\\u0413\\u043E\\u0442\\u043E\\u0432\\u043E \\u043A \\u0440\\u0430\\u0431\\u043E\\u0442\\u0435\\u00BB, \\u00AB\\u0412 \\u0440\\u0430\\u0431\\u043E\\u0442\\u0435\\u00BB, \\u00AB\\u0417\\u0430\\u0431\\u043B\\u043E\\u043A\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u043E\\u00BB, \\u00AB\\u041D\\u0430 \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u043A\\u0435\\u00BB, \\u00AB\\u0417\\u0430\\u0432\\u0435\\u0440\\u0448\\u0435\\u043D\\u043E\\u00BB \\u0438 \\u00AB\\u041E\\u0442\\u043C\\u0435\\u043D\\u0435\\u043D\\u043E\\u00BB. \\u042D\\u0442\\u0438 \\u0436\\u0435 \\u043F\\u043E\\u0434\\u043F\\u0438\\u0441\\u0438 \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u044E\\u0442\\u0441\\u044F \\u0432 \\u0441\\u043F\\u0438\\u0441\\u043A\\u0435 \\u0437\\u0430\\u0434\\u0430\\u0447 Activity Bar \\u0438 \\u0432 \\u0441\\u0432\\u0435\\u0434\\u0435\\u043D\\u0438\\u044F\\u0445 \\u043E \\u0437\\u0430\\u0434\\u0430\\u0447\\u0435. \\u0417\\u0430\\u0433\\u043E\\u043B\\u043E\\u0432\\u043E\\u043A \\u043A\\u0430\\u0436\\u0434\\u043E\\u0439 \\u043A\\u043E\\u043B\\u043E\\u043D\\u043A\\u0438 \\u043E\\u0431\\u044A\\u044F\\u0441\\u043D\\u044F\\u0435\\u0442 \\u0432 \\u043F\\u043E\\u0434\\u0441\\u043A\\u0430\\u0437\\u043A\\u0435 \\u043A\\u0440\\u0438\\u0442\\u0435\\u0440\\u0438\\u0439 \\u0440\\u0430\\u0437\\u043C\\u0435\\u0449\\u0435\\u043D\\u0438\\u044F. \\u041A\\u0430\\u043D\\u043E\\u043D\\u0438\\u0447\\u0435\\u0441\\u043A\\u0438\\u0435 \\u0437\\u043D\\u0430\\u0447\\u0435\\u043D\\u0438\\u044F Ready, InProgress, Blocked, Review, Done \\u0438 Cancelled, \\u0432\\u044B\\u0447\\u0438\\u0441\\u043B\\u044F\\u0435\\u043C\\u044B\\u0439 boardStatus \\u0438 \\u043A\\u043E\\u043C\\u0430\\u043D\\u0434\\u044B CLI \\u043E\\u0441\\u0442\\u0430\\u044E\\u0442\\u0441\\u044F \\u043D\\u0435\\u0438\\u0437\\u043C\\u0435\\u043D\\u043D\\u044B\\u043C\\u0438. \\u041E\\u0436\\u0438\\u0434\\u0430\\u043D\\u0438\\u0435 \\u043F\\u043E\\u043B\\u044C\\u0437\\u043E\\u0432\\u0430\\u0442\\u0435\\u043B\\u044C\\u0441\\u043A\\u043E\\u0433\\u043E \\u0440\\u0435\\u0448\\u0435\\u043D\\u0438\\u044F \\u043D\\u0435 \\u044F\\u0432\\u043B\\u044F\\u0435\\u0442\\u0441\\u044F \\u043E\\u0442\\u0434\\u0435\\u043B\\u044C\\u043D\\u043E\\u0439 \\u043A\\u043E\\u043B\\u043E\\u043D\\u043A\\u043E\\u0439: \\u0437\\u0430\\u0434\\u0430\\u0447\\u0430 \\u043E\\u0441\\u0442\\u0430\\u0451\\u0442\\u0441\\u044F \\u0432 Review, \\u0430 \\u0441\\u043E\\u0441\\u0442\\u043E\\u044F\\u043D\\u0438\\u0435 Open \\u0438\\u043B\\u0438 Submitted \\u043E\\u043F\\u0440\\u0435\\u0434\\u0435\\u043B\\u044F\\u0435\\u0442\\u0441\\u044F \\u0447\\u0435\\u0440\\u0435\\u0437 acceptanceState. \\u0413\\u043E\\u0442\\u043E\\u0432\\u0430\\u044F \\u0437\\u0430\\u0434\\u0430\\u0447\\u0430 \\u0441 \\u043D\\u0435\\u0437\\u0430\\u0432\\u0435\\u0440\\u0448\\u0451\\u043D\\u043D\\u043E\\u0439 \\u0438\\u043B\\u0438 \\u043E\\u0442\\u043C\\u0435\\u043D\\u0451\\u043D\\u043D\\u043E\\u0439 \\u0437\\u0430\\u0432\\u0438\\u0441\\u0438\\u043C\\u043E\\u0441\\u0442\\u044C\\u044E \\u043B\\u0438\\u0431\\u043E \\u0440\\u0443\\u0447\\u043D\\u043E\\u0439 \\u043F\\u0440\\u0438\\u0447\\u0438\\u043D\\u043E\\u0439 \\u0431\\u043B\\u043E\\u043A\\u0438\\u0440\\u043E\\u0432\\u043A\\u0438 \\u043E\\u0442\\u043E\\u0431\\u0440\\u0430\\u0436\\u0430\\u0435\\u0442\\u0441\\u044F \\u0432 \\u00AB\\u0417\\u0430\\u0431\\u043B\\u043E\\u043A\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u043E\\u00BB \\u0447\\u0435\\u0440\\u0435\\u0437 boardStatus \\u0431\\u0435\\u0437 \\u0438\\u0437\\u043C\\u0435\\u043D\\u0435\\u043D\\u0438\\u044F \\u0435\\u0451 \\u043A\\u0430\\u043D\\u043E\\u043D\\u0438\\u0447\\u0435\\u0441\\u043A\\u043E\\u0433\\u043E status.\"},{\"op\":\"replace\",\"path\":\"/acceptanceCriteria\",\"value\":[{\"criterionId\":\"six-russian-columns\",\"description\":\"\\u041E\\u0441\\u043D\\u043E\\u0432\\u043D\\u0430\\u044F \\u0434\\u043E\\u0441\\u043A\\u0430 \\u0432\\u0441\\u0435\\u0433\\u0434\\u0430 \\u043F\\u043E\\u043A\\u0430\\u0437\\u044B\\u0432\\u0430\\u0435\\u0442 \\u0448\\u0435\\u0441\\u0442\\u044C \\u043A\\u043E\\u043B\\u043E\\u043D\\u043E\\u043A \\u0441 \\u043F\\u043E\\u0434\\u043F\\u0438\\u0441\\u044F\\u043C\\u0438 \\u00AB\\u0413\\u043E\\u0442\\u043E\\u0432\\u043E \\u043A \\u0440\\u0430\\u0431\\u043E\\u0442\\u0435\\u00BB, \\u00AB\\u0412 \\u0440\\u0430\\u0431\\u043E\\u0442\\u0435\\u00BB, \\u00AB\\u0417\\u0430\\u0431\\u043B\\u043E\\u043A\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u043E\\u00BB, \\u00AB\\u041D\\u0430 \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u043A\\u0435\\u00BB, \\u00AB\\u0417\\u0430\\u0432\\u0435\\u0440\\u0448\\u0435\\u043D\\u043E\\u00BB \\u0438 \\u00AB\\u041E\\u0442\\u043C\\u0435\\u043D\\u0435\\u043D\\u043E\\u00BB; \\u043E\\u0442\\u0434\\u0435\\u043B\\u044C\\u043D\\u044B\\u0445 \\u043A\\u043E\\u043B\\u043E\\u043D\\u043E\\u043A Backlog \\u0438 AwaitingAcceptance \\u043D\\u0435\\u0442.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"shared-status-presentation\",\"description\":\"\\u0421\\u043F\\u0438\\u0441\\u043E\\u043A \\u0437\\u0430\\u0434\\u0430\\u0447 Activity Bar \\u0438 \\u0441\\u0432\\u0435\\u0434\\u0435\\u043D\\u0438\\u044F \\u043E \\u0437\\u0430\\u0434\\u0430\\u0447\\u0435 \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u044E\\u0442 \\u0442\\u0435 \\u0436\\u0435 \\u043B\\u043E\\u043A\\u0430\\u043B\\u0438\\u0437\\u043E\\u0432\\u0430\\u043D\\u043D\\u044B\\u0435 \\u043D\\u0430\\u0437\\u0432\\u0430\\u043D\\u0438\\u044F, \\u0447\\u0442\\u043E \\u0438 \\u0437\\u0430\\u0433\\u043E\\u043B\\u043E\\u0432\\u043A\\u0438 \\u043A\\u043E\\u043B\\u043E\\u043D\\u043E
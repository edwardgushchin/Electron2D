  "taskId": "T-1178",
  "legacyAliases": [],
  "title": "Сериализовать CLI-команды VS Code Task Board и повторять transient lock",
  "description": "VS Code расширение должно выполнять все CLI-вызовы одного workspace/executable через общую FIFO-очередь. Точный transient diagnostic Taskboard is locked by another writer повторяется с ограниченной задержкой; semantic и revision ошибки не повторяются. Очередь сохраняет порядок после ошибок и охватывает human acceptance bridge.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P0",
  "tagIds": [
    "tag-0001",
    "tag-0009",
    "tag-0017",
    "tag-0018"
  ],
  "deadline": null,
  "createdBy": "cli",
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "all-command-paths",
      "description": "Общая очередь и retry охватывают board/task reads, mutations, move и trusted human acceptance bridge без прямых обходных CLI-вызовов.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    },
    {
      "criterionId": "scheduler-fifo",
      "description": "Все CLI-вызовы расширения для одного workspace и executable выполняются последовательно в FIFO-порядке; ошибка одной команды не блокирует последующие, разные workspace не блокируют друг друга.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    },
    {
      "criterionId": "transient-lock-retry",
      "description": "Диагностика E2D-CLI-0002 Taskboard is locked by another writer автоматически повторяется с ограниченным backoff с сохранением позиции в очереди; semantic и revision ошибки не повторяются.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    },
    {
      "criterionId": "verification",
      "description": "RED/GREEN unit tests, typecheck, Extension Host concurrent scenario, VSIX packaging/install и repository gates проходят на реальном расширении.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    }

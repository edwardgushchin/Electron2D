  "acceptanceCriteria": [
    {
      "criterionId": "input-cancel-autoscroll",
      "description": "Mouse, touch и pen используют Pointer Events; обычный click открывает задачу, края запускают автопрокрутку, Escape/pointercancel/потеря окна полностью восстанавливают DOM, focus и исходную позицию.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "placement-only-rollback",
      "description": "Drop разрешён только внутри effective-status колонки, изменяет только groupId/rank через e2d tasks move, применяет оптимистичную позицию и откатывает её со стандартным VS Code alert при CLI/revision error.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "verification",
      "description": "Доменный документ и TDD regression покрывают sortable model/layout/input/recovery; unit, typecheck, Extension Host, VSIX package/install и реальный FFmpeg capture проходят.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "visual-sort",
      "description": "После порога движения карточка следует за pointer, сохраняет геометрию; placeholder той же высоты переставляется между карточками, а соседние карточки плавно освобождают место.",
      "state": "Open",
      "evidence": []
    }
  ],

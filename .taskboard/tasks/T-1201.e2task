  "acceptanceCriteria": [
    {
      "criterionId": "domain-contract",
      "description": "`docs/editor/editor-project-shell.md` описывает общий process-test runner, значения timeout, двухфазное завершение дерева, диагностику и запрет неограниченного ожидания.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "shared-runner",
      "description": "Все process-based Editor integration tests используют один helper, который одновременно считывает stdout/stderr, принимает timeout и cancellation и возвращает единый результат запуска.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "bounded-tree-termination",
      "description": "При timeout или отмене helper вызывает завершение всего process tree, ограниченно ждёт его остановки и подтверждает отсутствие живых дочерних `dotnet`, MSBuild, Editor и game processes.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "timeout-diagnostics",
      "description": "Timeout failure содержит executable и arguments, PID, elapsed time, timeout, exit reason, последние stdout/stderr и доступные пути к screenshot, analysis, dump или другому diagnostic artifact.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "no-nested-build",
      "description": "Editor smoke tests используют заранее собранный apphost/assembly либо `--no-build --no-restore`; full suite не выполняет отдельную вложенную сборку Editor для каждого теста.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "regression-watchdog",
      "description": "Автоматический regression test запускает контролируемо зависающий процесс с дочерним процессом, завершается существенно раньше минутного лимита, сохраняет stdout/stderr и доказывает отсутствие orphan process tree.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "static-guard",
      "description": "Статическая проверка охватывает все process-based Editor tests и отклоняет прямые `WaitForExit`, `WaitForExitAsync` либо собственные timeout-петли вне общего helper.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "verification",
      "description": "Focused helper regressions, все Editor process tests и полный integration suite с `--blame-hang-timeout` завершаются в заданных пределах; повторные smoke-запуски не оставляют процессов, документация, licenses и `git diff --check` проходят.",
      "state": "Open",
      "evidence": []
    }
  ],

  "executionContract": {
    "taskType": "test-infrastructure",
    "readyToStart": [
      "Поведение текущих Editor smoke и список process-based integration tests зафиксированы до изменения helper.",
      "Доменный документ обновлён до production/test-infrastructure кода, а regression watchdog сначала подтверждён красным тестом."
    ],
    "stopConditions": [
      "Для завершения дерева процессов требуется изменение production Editor или runtime поведения вместо test infrastructure.",
      "Выбранный способ скрывает зависание увеличением общего timeout либо ослабляет существующие smoke assertions.",
      "Невозможно надёжно отличить дочерние процессы теста от посторонних пользовательских процессов."
    ],
    "allowedChanges": [
      "Общий process runner и его тестовые helpers в `tests/Electron2D.Tests.Integration`.",
      "Process-based Editor integration tests и их bounded launch contract.",
      "`docs/editor/editor-project-shell.md` и связанная проверка repository workflow.",
      "Минимальная build-test plumbing, необходимая для запуска заранее собранного Editor без вложенной сборки."
    ],
    "forbiddenChanges": [
      "Production Editor startup, runtime rendering/input, taskboard schema и пользовательское поведение smoke-команд.",
      "Увеличение timeout до десятков минут, удаление smoke assertions или исключение тестов из полного suite.",
      "Завершение процессов по имени без доказанной принадлежности дереву конкретного test launch.",
      "Исправление несвязанных текущих падений integration suite внутри этой задачи."
    ],
    "requiredOutputs": [
      "Переиспользуемый bounded process runner с документированными значениями timeout и kill grace period.",
      "Regression evidence для зависшего родителя и потомка без orphan processes.",
      "Инвентаризация всех мигрированных Editor process tests и статическая защита от возврата неограниченного ожидания.",
      "Логи focused и full integration запусков с hang watchdog и итоговым временем."
    ],

{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-759832a0f0c44542bd4d18de09b24bba",
  "revision": 24,
  "taskId": "T-1218",
  "legacyAliases": [],
  "title": "Добавить фильтр по тегам в VS Code Task Board",
  "description": "Существующий filter popover VS Code Task Board содержит только выбор приоритета. Нужно добавить локализованный компактный multi-select по актуальному общему каталогу тегов: пользователь может выбрать несколько тегов, видит их имена, а локальное состояние хранит canonical tagId. Задача проходит tag-фильтр, только если содержит все выбранные tagId; tag dimension объединяется логическим AND с текстовым поиском, priority и archive-toggle. Badge считает активные dimensions, поэтому любое непустое множество тегов добавляет одну единицу. Refresh сохраняет существующие выбранные tagId и удаляет из выбора только исчезнувшие определения. Клик внутри панели позволяет выбрать несколько значений подряд, а клик по рабочей поверхности или в любом месте вне фильтров закрывает внутренний список и весь filter popover без сброса выбора. Фильтрация остаётся локальным presentation state без taskboard mutations.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P2",
  "tagIds": [
    "tag-0001",
    "tag-0002",
    "tag-0003",
    "tag-0009",
    "tag-0013"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "catalog-tag-select",
      "description": "Filter popover под выбором приоритета показывает локализованный компактный multi-select «Теги»: закрытое состояние обозначает отсутствие выбора, один тег или количество выбранных тегов; раскрытый список строится из актуального общего каталога доски, показывает имена и позволяет независимо выбрать несколько canonical tagId.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/webviewHtml.ts"
        }
      ]
    },
    {
      "criterionId": "combined-filter-semantics",
      "description": "Непустой набор тегов оставляет только задачи, чьи labels содержат каждый выбранный tagId; tag dimension объединяется логическим AND с текстовым поиском, приоритетом и archive-toggle, не меняя status, placement или canonical данные задач.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/model.ts"
        }
      ]
    },
    {
      "criterionId": "refresh-and-count",
      "description": "Badge кнопки «Фильтры» показывает число активных dimensions от 0 до 2: любое непустое множество тегов считается одной dimension. При refresh сохраняются все выбранные tagId, существующие в новом каталоге, а исчезнувшие удаляются из набора независимо от остальных.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/webview.ts"
        }
      ]
    },
    {
      "criterionId": "localized-accessible-layout",
      "description": "Русская и английская локализации содержат подписи «Теги»/«Tags», «Все теги»/«All tags» и счётчик выбранных тегов; trigger и listbox имеют связанную label, aria-multiselectable/aria-selected, keyboard navigation и VS Code themed layout без выхода за filter popover.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/localization.ts"
        }
      ]
    },
    {
      "criterionId": "outside-click-close",
      "description": "Клики внутри filter popover не закрывают его и позволяют выбрать несколько тегов подряд; pointerdown вне кнопки и панели фильтров, включая рабочую поверхность доски, закрывает внутренний tag popup и внешний filter popover, сохраняя выбранные значения.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/webview.ts"
        }
      ]
    },
    {
      "criterionId": "verification",
      "description": "Model/HTML/layout/localization tests проходят через ожидаемый RED и GREEN; полный unit-набор, typecheck, VSIX и FFmpeg-снимок установленного расширения подтверждают выбор нескольких тегов, их пересечение и комбинацию с приоритетом.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-t1218-multi-tag-priority-filter.png"
        }
      ]
    }
  ],

{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-89407b4e4bc1488b91b85d36eaf5c607",
  "revision": 25,
  "taskId": "T-1226",
  "legacyAliases": [],
  "title": "Выровнять число задач по центру счётчика колонки",
  "description": "Число внутри круглого badge рядом с названием статусной колонки визуально смещено относительно центра: текущий `.column-count` задаёт только горизонтальный `text-align`, а вертикальное положение зависит от метрик шрифта, `line-height: 1.2` и padding. Нужно сделать сам badge двухмерным alignment-контейнером и центрировать значение независимо от baseline. Исправление должно одинаково работать для `0`, однозначных, двухзначных и трёхзначных счётчиков во всех шести колонках, при разных темах и масштабе VS Code. Минимальная ширина, горизонтальный padding, pill-форма и динамическое расширение под число сохраняются; цифры не обрезаются, а высота и расположение заголовка колонки, status accent и соседние controls не меняются. Семантика count остаётся прежней: отображается фактическое число задач после действующих фильтров.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P2",
  "tagIds": [
    "tag-0001",
    "tag-0002",
    "tag-0003",
    "tag-0010",
    "tag-0017"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "criterion-column-count-center",
      "description": "`.column-count` использует явное двухмерное центрирование, поэтому видимая цифра находится по центру pill-контейнера по горизонтали и вертикали и не зависит от baseline или default line box текущего шрифта.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/webview.css"
        }
      ]
    },
    {
      "criterionId": "criterion-column-count-values",
      "description": "Значения `0`, `4`, `29` и `913` не обрезаются и остаются центрированными; badge сохраняет минимальную ширину, pill-форму и симметричный горизонтальный запас, расширяясь только по содержимому.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-column-count-centered-real.png"
        }
      ]
    },
    {
      "criterionId": "criterion-column-count-layout",
      "description": "Высота `.column-header`, положение title/status accent, интервал между title и badge, а также соседние filter/overflow и collapse controls не сдвигаются. Исправление работает во всех шести колонках, в светлой и тёмной теме и при увеличенном масштабе текста.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-column-count-centered-real.png"
        }
      ]
    },
    {
      "criterionId": "criterion-column-count-semantics",
      "description": "Renderer по-прежнему показывает `tasks.length` итогового видимого набора; фильтры, collapse, preview `+ N ещё`, status/rank и canonical task data не меняются. Специальных поправок для конкретной цифры или шрифта нет.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/src/webview.ts"
        }
      ]
    },
    {
      "criterionId": "criterion-column-count-verification",
      "description": "Доменный документ обновлён до production-кода; focused layout test сначала фиксирует RED на отсутствии двухмерного центрирования и затем GREEN. Полный unit-набор, typecheck, VSIX и FFmpeg-снимок установленного расширения подтверждают центрирование реального однозначного и многозначного count без изменения header geometry.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/webview-layout.test.ts"
        }
      ]
    }
  ],

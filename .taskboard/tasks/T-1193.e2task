{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-03beb043f63d43e88bf09d91d5bf3601",
  "revision": 24,
  "taskId": "T-1193",
  "legacyAliases": [],
  "title": "Восстанавливать перемещение после конфликта ревизии доски",
  "description": "Добавить в VS Code Task Board восстановление после оптимистического конфликта ревизии доски для безопасного перемещения карточки. При точном `Taskboard revision conflict` расширение внутри общей очереди перечитывает компактный снимок доски, публикует свежий интерфейс, проверяет существование задачи и целевой группы и повторяет `tasks move` с актуальной `board.revision`. Повтор ограничен; семантические ошибки, неприменимое намерение и исчерпанный конфликт остаются стандартным VS Code alert. Обновить `docs/editor/project-tasks-board.md`, модульные тесты и Extension Host tests, собрать и проверить реальный VSIX.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0009"
  ],
  "deadline": null,
  "createdBy": "cli",
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "applicability-and-limits",
      "description": "Повтор выполняется только пока задача и целевая группа существуют, ограничен тремя попытками и не применяется к другим диагностическим ошибкам.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    },
    {
      "criterionId": "automated-conflict-proof",
      "description": "Модульный тест подтверждает RED/GREEN оркестратора, а Extension Host воспроизводит внешнюю команду `tasks move` между чтением и записью без `lastError`.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    },
    {
      "criterionId": "installed-runtime-proof",
      "description": "VSIX собран и установлен; реальный VS Code показывает актуальную доску после конкурентного изменения, а PNG получен только через `eng/tools/capture_window.py`.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    },
    {
      "criterionId": "refresh-and-retry",
      "description": "При точном конфликте ревизии `tasks move` расширение перечитывает компактный снимок доски, обновляет `webview` и повторяет исходное намерение с актуальной `board.revision` внутри той же очереди рабочей области.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/extension-core.test.ts"
        }
      ]
    }
  ],

  ],
  "acceptanceCriteria": [
    {
      "criterionId": "criterion-explorer-parity",
      "description": "Для одного и того же repository file путь в блоке «Связанные файлы» показывает тот же file-type icon, что и Explorer текущего окна VS Code: совпадают источник темы, геометрия, цвет и различимость; собственные приблизительные SVG не считаются паритетом.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-active-file-icon-theme",
      "description": "Иконки следуют активной File Icon Theme и обновляются после её смены без перезапуска Extension Host; темы `None`, встроенная тема и сторонняя тема обрабатываются детерминированно в пределах поддерживаемого публичного контракта VS Code.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-supported-file-kinds",
      "description": "Паритет проверен для Markdown/README, JSON, JavaScript, TypeScript, CSS, C#, project, image, archive, VSIX и неизвестного расширения; имя файла и составной extension учитываются так же, как в Explorer.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-safe-theme-assets",
      "description": "Решение использует только поддерживаемый VS Code API или явно лицензированные локальные assets: запрещены private API, чтение внутренних файлов установки VS Code, небезопасное копирование assets сторонних тем, `innerHTML`, внешние сетевые ресурсы и literal palette, расходящаяся с темой.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-fallback-and-layout",
      "description": "Если конкретный theme icon недоступен, применяется документированный fallback, согласованный с состоянием Explorer и не маскирующий ошибку; строки сохраняют текущие размеры, выравнивание, ellipsis, tooltip, keyboard accessibility и безопасное открытие файла.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-tests-and-visual-evidence",
      "description": "До production-кода обновлён доменный документ и добавлены RED-тесты; затем проходят focused/full unit, typecheck, Extension Host и VSIX package/install, а снимок реального окна показывает бок о бок совпадающие значки Explorer и «Связанных файлов» минимум для шести разных типов.",
      "state": "Open",
      "evidence": []
    }
  ],

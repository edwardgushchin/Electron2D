447\\u0430\\u043C \\u0443\\u0436\\u0435 \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u044E\\u0442\\u0441\\u044F \\u0432 Task Board.\"],\"stopConditions\":[\"\\u0414\\u043B\\u044F \\u0438\\u0437\\u043C\\u0435\\u043D\\u0435\\u043D\\u0438\\u044F \\u0442\\u0440\\u0435\\u0431\\u0443\\u0435\\u0442\\u0441\\u044F \\u043C\\u0435\\u043D\\u044F\\u0442\\u044C canonical TaskBoard schema, lifecycle \\u0438\\u043B\\u0438 \\u0434\\u0430\\u043D\\u043D\\u044B\\u0435 \\u0437\\u0430\\u0434\\u0430\\u0447.\",\"\\u0421\\u0432\\u044F\\u0437\\u0430\\u043D\\u043D\\u044B\\u0435 \\u0437\\u0430\\u0434\\u0430\\u0447\\u0438 \\u043D\\u0435\\u043B\\u044C\\u0437\\u044F \\u043F\\u043E\\u043B\\u0443\\u0447\\u0438\\u0442\\u044C \\u0438\\u0437 \\u0442\\u0435\\u043A\\u0443\\u0449\\u0435\\u0433\\u043E \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u0435\\u043D\\u043D\\u043E\\u0433\\u043E \\u0441\\u043D\\u0438\\u043C\\u043A\\u0430 \\u0431\\u0435\\u0437 \\u0434\\u043E\\u0431\\u0430\\u0432\\u043B\\u0435\\u043D\\u0438\\u044F \\u043D\\u0435\\u043F\\u043E\\u0434\\u0442\\u0432\\u0435\\u0440\\u0436\\u0434\\u0451\\u043D\\u043D\\u043E\\u0433\\u043E \\u0438\\u0441\\u0442\\u043E\\u0447\\u043D\\u0438\\u043A\\u0430 \\u0434\\u0430\\u043D\\u043D\\u044B\\u0445.\"],\"allowedChanges\":[\"\\u0414\\u043E\\u043C\\u0435\\u043D\\u043D\\u044B\\u0439 \\u0434\\u043E\\u043A\\u0443\\u043C\\u0435\\u043D\\u0442, renderer, \\u0441\\u0442\\u0438\\u043B\\u0438, \\u043B\\u043E\\u043A\\u0430\\u043B\\u0438\\u0437\\u0430\\u0446\\u0438\\u044F \\u0438 \\u0446\\u0435\\u043B\\u0435\\u0432\\u044B\\u0435 unit/layout-\\u0442\\u0435\\u0441\\u0442\\u044B VS Code Task Board.\",\"\\u0421\\u0431\\u043E\\u0440\\u043A\\u0430 \\u0438 \\u0443\\u0441\\u0442\\u0430\\u043D\\u043E\\u0432\\u043A\\u0430 VSIX, \\u0440\\u0435\\u0430\\u043B\\u044C\\u043D\\u0430\\u044F \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u043A\\u0430 \\u0447\\u0435\\u0440\\u0435\\u0437 tracked FFmpeg-helper, task activity \\u0438 append-only \\u0434\\u043D\\u0435\\u0432\\u043D\\u0438
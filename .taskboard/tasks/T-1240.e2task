  "executionContract": {
    "taskType": "доступная визуальная индикация статуса карточек VS Code Task Board",
    "readyToStart": [
      "Родительская T-1147 принята; задача не имеет зависимостей и внешних блокеров.",
      "Текущий renderer уже содержит общий контейнер `card-indicators` и индикаторы для блокировки, ожидания решения и завершения.",
      "Перед production-кодом доменный документ должен зафиксировать семантику трёх новых значков и правило reduced motion."
    ],
    "stopConditions": [
      "Исправление потребует изменить канонические `TaskStatus`, `boardStatus`, acceptance lifecycle или расположение карточки по колонкам.",
      "Доступную анимацию нельзя реализовать без JavaScript-таймера, внешнего asset или игнорирования `prefers-reduced-motion`.",
      "Проверка обнаружит, что статусный значок конфликтует с dependency/blocker/acceptance indicator и требует отдельного продуктового решения."
    ],
    "allowedChanges": [

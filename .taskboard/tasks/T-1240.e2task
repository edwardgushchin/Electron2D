  "acceptanceCriteria": [
    {
      "criterionId": "missing-status-indicators",
      "description": "Карточки в эффективных состояниях «Готово к работе», «В работе» и «Отменено» получают отдельные локализованные статусные индикаторы; существующие индикаторы блокировки, ожидания решения и завершения продолжают отображаться как прежде.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "animated-in-progress-spinner",
      "description": "Индикатор «В работе» изображён неполной круговой SVG-дугой, которая плавно и непрерывно вращается вокруг собственного центра только для карточек в состоянии `InProgress`; вращение не меняет геометрию footer.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "ready-and-cancelled-semantics",
      "description": "«Готово к работе» использует понятный статический SVG готовности/запуска, а «Отменено» — статический SVG перечёркнутого круга; оба значка визуально различимы и не дублируют смысл блокировки или завершения.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "accessible-reduced-motion",
      "description": "Каждый новый индикатор имеет локализованные `title` и `aria-label`; при `prefers-reduced-motion: reduce` вращение отключается, но статическая дуга и доступное название состояния сохраняются.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "theme-and-layout-integrity",
      "description": "Значки создаются через DOM SVG API, используют `currentColor` и переменные темы VS Code, имеют единый размер и выравнивание с текущими индикаторами; Unicode-глифы, icon font, внешний asset и JavaScript-таймер не применяются.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "regression-and-real-window-proof",
      "description": "Unit-тесты покрывают три новых состояния, SVG-разметку, CSS-анимацию и reduced-motion; typecheck, Extension Host и упаковка VSIX проходят, а проверенный FFmpeg-снимок реального окна VS Code подтверждает значки в карточках без поломки footer.",
      "state": "Open",
      "evidence": []
    }
  ],

  "acceptanceCriteria": [
    {
      "criterionId": "criterion-column-filter-control",
      "description": "В заголовке каждой из шести статусных колонок кнопка `⋮` и её действие «раскрыть всё» отсутствуют. На том же месте находится локализованная SVG-кнопка фильтра с tooltip, доступным именем и badge активных измерений; существующая кнопка сворачивания колонки остаётся отдельной.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-column-filter-scope",
      "description": "У каждой колонки есть независимый выбор приоритета и нескольких тегов. Изменение фильтра одной колонки не меняет локальные условия и набор карточек остальных колонок; выбранные теги внутри колонки используют пересечение всех значений.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-column-filter-composition",
      "description": "Локальный фильтр дополнительно сужает результат глобального поиска, глобального приоритета, глобальных тегов и archive toggle через логическое `AND`. Счётчик колонки, пустое состояние и `+ N ещё` используют итоговый отфильтрованный набор, а status/rank и canonical task data не меняются.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-column-filter-state",
      "description": "Выбор хранится по canonical status, переживает `renderBoard`, сворачивание и refresh, сохраняет доступные tagId и удаляет только исчезнувшие определения каталога. Badge считает приоритет и непустой набор тегов как два независимых измерения и не зависит от числа выбранных тегов.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-column-filter-popover",
      "description": "Панель повторяет локализацию, тему, keyboard navigation и multi-select семантику глобального фильтра, не расширяет колонку и не обрезается на минимальной ширине. Одновременно открыта не более чем одна глобальная или локальная панель; `Escape`, outside click и выбор другой колонки закрывают предыдущую панель без сброса значений и возвращают предсказуемый focus.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "criterion-column-filter-verification",
      "description": "Доменный документ обновлён до production-кода; RED/GREEN tests покрывают независимость шести состояний, объединение с глобальными условиями, синхронизацию тегов, count/preview и доступность. Полный unit-набор, typecheck, VSIX и FFmpeg-снимки установленного расширения подтверждают закрытую и открытую панели, активный badge и отсутствие overflow.",
      "state": "Open",
      "evidence": []
    }
  ],

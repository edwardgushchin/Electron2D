  "executionContract": {
    "taskType": "локальная фильтрация карточек внутри статусной колонки VS Code Task Board",
    "readyToStart": [
      "Зависимая `T-1218` принята человеком, а семантика глобального фильтра по приоритету и нескольким тегам считается устойчивой основой для повторного использования.",
      "`docs/editor/project-tasks-board.md` до production-кода определяет область локального фильтра, объединение с глобальными условиями, count/preview и правила popover/focus.",
      "До реализации добавлены падающие tests для per-status state, matching composition, refresh synchronization, DOM controls и адаптивного layout."
    ],
    "stopConditions": [
      "Фильтрация требует mutation задач, статусов, rank, labels, каталога тегов или ручного редактирования `.taskboard`.",
      "Нельзя изолировать состояние по колонкам либо корректно объединить локальные условия с глобальным поиском, фильтрами и archive toggle.",
      "Локальная панель расходится с keyboard, localization или multi-select поведением глобального фильтра и требует двух независимых несовместимых реализаций.",
      "Popover нельзя показать на минимальной ширине колонки без изменения min/fluid/max геометрии доски или без реальной FFmpeg-проверки."
    ],
    "allowedChanges": [
      "Доменный документ, model/webview/HTML/CSS/localization VS Code Task Board и связанные unit tests.",
      "Generated docs index, устанавливаемый VSIX, task activity, локальные FFmpeg-артефакты и append-only дневник."
    ],
    "forbiddenChanges": [
      "Изменение TaskBoard schema, CLI writer boundary, lifecycle, placement/rank, содержимого задач или каталога тегов.",
      "Несвязанный рефакторинг карточек, Task Details, drag-and-drop, toolbar или расширение локального фильтра новыми измерениями сверх глобальной панели.",
      "Сохранение presentation state в `.taskboard`, автоматическая приёмка зависимой задачи или ручное редактирование `.e2task`/`.e2tasks`."
    ],
    "requiredOutputs": [
      "Шесть независимых локальных фильтров в заголовках колонок вместо `⋮`, с приоритетом, multi-select тегами и badge активных измерений.",
      "Единая matching-семантика глобальных и локальных условий, корректные count/preview и устойчивое состояние при refresh без taskboard mutations.",
      "Синхронизированный доменный документ, RED/GREEN tests, собранный VSIX и FFmpeg-доказательство из реального окна VS Code."
    ],

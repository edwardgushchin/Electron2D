  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "vertical-board-scroll",
      "description": "Длинная status column увеличивает общую прокручиваемую высоту board, последняя карточка доступна через вертикальный scrollbar, без отката left alignment и horizontal scroll.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    }
  ],

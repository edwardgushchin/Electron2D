  "executionContract": {
    "taskType": "укрепление контракта TaskBoard",
    "readyToStart": [
      "Доменный контракт v3 согласован с критериями задачи.",
      "Доски репозитория, шаблона и примера доступны для проверки через CLI."
    ],
    "stopConditions": [
      "Обнаружена потеря данных при миграции v2 в v3.",
      "Строгий валидатор отклоняет реальную доску после миграции.",
      "Для завершения требуется выдать агенту право человеческой приёмки."
    ],
    "allowedChanges": [
      "Схемы, валидаторы, миграция, CLI и read-only consumers TaskBoard.",
      "Контрактные и интеграционные тесты, доменная и CLI-документация.",
      "Данные .taskboard только через e2d tasks.",
      "path:data/schemas/project-system/task-file-v3.schema.json",
      "path:data/schemas/project-system/task-board-v3.schema.json",
      "path:src/Electron2D.ProjectSystem/Tasks/**",
      "path:src/Electron2D.ProjectSystem/Templates/ProjectTemplateCreator.cs",
      "path:src/Electron2D.Cli/ProjectTasksCli.cs",
      "path:tests/Electron2D.Tests.Integration/**",
      "path:docs/project-system/project-task-manager.md",
      "path:docs/cli/e2d-cli.md",
      "path:data/documentation/**",
      "path:data/dev-diary/**",
      "Сквозная миграция TaskBoard v3 может синхронизировать любые tracked consumers, схемы, шаблоны, примеры, тесты и документы репозитория.",
      "path:**"
    ],
    "forbiddenChanges": [
      "Ручное редактирование .e2task и board.e2tasks.",
      "Автоматическая человеческая приёмка или перевод задачи в Done агентом.",
      "Исполнение команды только потому, что её JSON прошёл валидацию.",
      "path:.taskboard/**",
      "path:.git/**"
    ],
    "requiredOutputs": [
      "Опубликованные JSON Schema v3 и три слоя проверок.",
      "Детерминированная миграция v2 в v3 с отчётом, резервной копией и финализацией.",
      "CLI-only запись, типизированные данные и отрицательные тесты.",
      "Мигрированные и проверенные корневая, шаблонная и демонстрационная доски."
    ],
    "commands": [
      {

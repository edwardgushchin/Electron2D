        {
          "kind": "File",
          "path": "docs/release-management/audit-package.md"
        }
      ]
    },
    {
      "criterionId": "execution-contract",
      "description": "Execution contract использует типизированные command specs с executable, arguments, cwd, platform, timeout, expected exit codes, permission и confirmation policy. JSON-валидность никогда не означает разрешение выполнить команду; legacy shell text сохраняется как запрещённый до ручной проверки объект.",
      "state": "Passed",
      "evidence": [

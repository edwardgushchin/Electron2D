        "sourceKind": "TaskPatchedV3Draft",
        "text": "{\"patch\":[{\"op\":\"replace\",\"path\":\"/acceptanceCriteria\",\"value\":[{\"criterionId\":\"atomic-revision\",\"description\":\"Transition validator \\u043F\\u0440\\u0438\\u043D\\u0438\\u043C\\u0430\\u0435\\u0442 \\u0442\\u043E\\u043B\\u044C\\u043A\\u043E revision \\u002B 1, \\u0441\\u043E\\u0445\\u0440\\u0430\\u043D\\u044F\\u0435\\u0442 taskUid, boardId, createdAt \\u0438 createdBy, \\u0442\\u0440\\u0435\\u0431\\u0443\\u0435\\u0442 \\u043F\\u043E\\u043B\\u043D\\u043E\\u043C\\u043E\\u0447\\u0438\\u044F \\u0434\\u043B\\u044F audit/acceptance \\u043F\\u043E\\u043B\\u0435\\u0439 \\u0438 \\u043F\\u043E\\u0434\\u0442\\u0432\\u0435\\u0440\\u0436\\u0434\\u0430\\u0435\\u0442 append-only activity; stale CAS \\u0438 \\u043B\\u044E\\u0431\\u0430\\u044F \\u043E\\u0448\\u0438\\u0431\\u043A\\u0430 \\u043D\\u0435 \\u043E\\u0441\\u0442\\u0430\\u0432\\u043B\\u044F\\u044E\\u0442 \\u0447\\u0430\\u0441\\u0442\\u0438\\u0447\\u043D\\u043E\\u0439 \\u0437\\u0430\\u043F\\u0438\\u0441\\u0438.\",\"state\":\"Passed\",\"evidence\":[{\"kind\":\"File\",\"path\":\"src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Validation.cs\"},{\"kind\":\"File\",\"path\":\"tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs\"}]},{\"criterionId\":\"docs-and-cutover\",\"description\":\"\\u0414\\u043E\\u043C\\u0435\\u043D\\u043D\\u044B\\u0439 \\u0438 CLI-\\u0434\\u043E\\u043A\\u0443\\u043C\\u0435\\u043D\\u0442\\u044B, schema v3, \\u043C\\u0438\\u0433\\u0440\\u0430\\u0446\\u0438\\u043E\\u043D\\u043D\\u044B\\u0439 \\u043E\\u0442\\u0447\\u0451\\u0442 \\u0438 \\u043C\\u0430\\u0442\\u0440\\u0438\\u0446\\u0430 \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u043E\\u043A \\u0441\\u0438\\u043D\\u0445\\u0440\\u043E\\u043D\\u0438\\u0437\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u044B. Root, template \\u0438 platformer \\u0434\\u043E\\u0441\\u043A\\u0438 \\u043C\\u0438\\u0433\\u0440\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u044B \\u0447\\u0435\\u0440\\u0435\\u0437 CLI, \\u043F\\u0435\\u0440\\u0435\\u0447\\u0438\\u0442\\u0430\\u043D\\u044B \\u0432\\u0441\\u0435\\u043C\\u0438 consumers \\u0438 \\u043F\\u0440\\u043E\\u0445\\u043E\\u0434\\u044F\\u0442 verify; v2 \\u043E\\u0441\\u0442\\u0430\\u0451\\u0442\\u0441\\u044F \\u0442\\u043E\\u043B\\u044C\\u043A\\u043E \\u0432\\u0445\\u043E\\u0434\\u043E\\u043C \\u043C\\u0438\\u0433\\u0440\\u0430\\u0446\\u0438\\u0438.\",\"state\":\"Passed\",\"evidence\":[{\"kind\":\"File\",\"path\":\"docs/project-system/project-task-manager.md\"},{\"kind\":\"File\",\"path\":\"docs/cli/e2d-cli.md\"},{\"kind\":\"File\",\"path\":\"docs/release-management/audit-package.md\"}]},{\"criterionId\":\"execution-contract\",\"description\":\"Execution contract \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u0435\\u0442 \\u0442\\u0438\\u043F\\u0438\\u0437\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u043D\\u044B\\u0435 command specs \\u0441 executable, arguments, cwd, platform, timeout, expected exit codes, permission \\u0438 confirmation policy. JSON-\\u0432\\u0430\\u043B\\u0438\\u0434\\u043D\\u043E\\u0441\\u0442\\u044C \\u043D\\u0438\\u043A\\u043E\\u0433\\u0434\\u0430 \\u043D\\u0435 \\u043E\\u0437\\u043D\\u0430\\u0447\\u0430\\u0435\\u0442 \\u0440\\u0430\\u0437\\u0440\\u0435\\u0448\\u0435\\u043D\\u0438\\u0435 \\u0432\\u044B\\u043F\\u043E\\u043B\\u043D\\u0438\\u0442\\u044C \\u043A\\u043E\\u043C\\u0430\\u043D\\u0434\\u0443; legacy shell text \\u0441\\u043E\\u0445\\u0440\\u0430\\u043D\\u044F\\u0435\\u0442\\u0441\\u044F \\u043A\\u0430\\u043A \\u0437\\u0430\\u043F\\u0440\\u0435\\u0449\\u0451\\u043D\\u043D\\u044B\\u0439 \\u0434\\u043E \\u0440\\u0443\\u0447\\u043D\\u043E\\u0439 \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u043A\\u0438 \\u043E\\u0431\\u044A\\u0435\\u043A\\u0442.\",\"state\":\"Passed\",\"evidence\":[{\"kind\":\"File\",\"path\":\"src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Security.cs\"},{\"kind\":\"File\",\"path\":\"data/schemas/project-system/task-file-v3.schema.json\"}]},{\"criterionId\":\"field-matrix\",\"description\":\"TaskFile \\u0438 TaskBoard v3 \\u0434\\u043E\\u043A\\u0443\\u043C\\u0435\\u043D\\u0442\\u0438\\u0440\\u0443\\u044E\\u0442 \\u043A\\u0430\\u0436\\u0434\\u043E\\u0435 \\u043F\\u043E\\u043B\\u0435, \\u0435\\u0433\\u043E \\u0440\\u0430\\u0437\\u043C\\u0435\\u0440, \\u0438\\u0441\\u0442\\u043E\\u0447\\u043D\\u0438\\u043A \\u0438\\u0441\\u0442\\u0438\\u043D\\u044B, \\u0438\\u0437\\u043C\\u0435\\u043D\\u044F\\u0435\\u043C\\u043E\\u0441\\u0442\\u044C \\u0438 \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u044F\\u044E\\u0449\\u0438\\u0439 \\u0441\\u043B\\u043E\\u0439. v2 \\u043D\\u0435 \\u043C\\u0435\\u043D\\u044F\\u0435\\u0442\\u0441\\u044F \\u043D\\u0435\\u0441\\u043E\\u0432\\u043C\\u0435\\u0441\\u0442\\u0438\\u043C\\u043E, \\u0430 \\u043F\\u0435\\u0440\\u0435\\u0432\\u043E\\u0434 \\u0432\\u044B\\u043F\\u043E\\u043B\\u043D\\u044F\\u0435\\u0442 \\u043E\\u0442\\u0434\\u0435\\u043B\\u044C\\u043D\\u0430\\u044F \\u0434\\u0435\\u0442\\u0435\\u0440\\u043C\\u0438\\u043D\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u043D\\u0430\\u044F \\u043C\\u0438\\u0433\\u0440\\u0430\\u0446\\u0438\\u044F v2\\u2192v3.\",\"state\":\"Passed\",\"evidence\":[{\"kind\":\"File\",\"path\":\"docs/project-system/project-task-manager.md\"},{\"kind\":\"File\",\"path\":\"data/schemas/project-system/task-board-v3.schema.json\"}]},{\"criterionId\":\"lifecycle-contract\",\"description\":\"Schema v3 \\u0438 transition validator \\u043E\\u0442\\u043A\\u043B\\u043E\\u043D\\u044F\\u044E\\u0442 \\u043D\\u0435\\u0432\\u043E\\u0437\\u043C\\u043E\\u0436\\u043D\\u044B\\u0435 \\u0441\\u043E\\u0447\\u0435\\u0442\\u0430\\u043D\\u0438\\u044F status, acceptanceState, timestamps, acceptedBy, cancellation reason, blockers, archive state \\u0438 criteria; \\u0442\\u0430\\u0431\\u043B\\u0438\\u0446\\u0430 \\u043F\\u0435\\u0440\\u0435\\u0445\\u043E\\u0434\\u043E\\u0432 \\u044F\\u0432\\u043B\\u044F\\u0435\\u0442\\u0441\\u044F \\u044F\\u0432\\u043D\\u043E\\u0439 \\u0438 \\u043F\\u043E\\u043A\\u0440\\u044B\\u0442\\u0430 \\u043D\\u0435\\u0433\\u0430\\u0442\\u0438\\u0432\\u043D\\u044B\\u043C\\u0438 \\u0442\\u0435\\u0441\\u0442\\u0430\\u043C\\u0438.\",\"state\":\"Passed\",\"evidence\":[{\"kind\":\"File\",\"path\":\"src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Validation.cs\"},{\"kind\":\"File\",\"path\":\"tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs\"}]},{\"criterionId\":\"linked-references\",\"description\":\"\\u0412\\u0441\\u0435 \\u043C\\u0435\\u0436\\u0437\\u0430\\u0434\\u0430\\u0447\\u043D\\u044B\\u0435 \\u0441\\u0441\\u044B\\u043B\\u043A\\u0438 \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u044E\\u0442 taskUid. Task \\u0445\\u0440\\u0430\\u043D\\u0438\\u0442 boardId, \\u0442\\u043E\\u043B\\u044C\\u043A\\u043E parentTaskUid \\u0431\\u0435\\u0437 \\u0434\\u0443\\u0431\\u043B\\u0438\\u0440\\u0443\\u044E\\u0449\\u0435\\u0433\\u043E \\u043C\\u0430\\u0441\\u0441\\u0438\\u0432\\u0430 \\u0434\\u0435\\u0442\\u0435\\u0439, \\u0442\\u0438\\u043F\\u0438\\u0437\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u043D\\u044B\\u0435 relations/tagIds/artifacts/scenes/resources/nodes; \\u043E\\u0442\\u0441\\u0443\\u0442\\u0441\\u0442\\u0432\\u0443\\u044E\\u0449\\u0438\\u0435, \\u0441\\u0430\\u043C\\u043E\\u0441\\u0441\\u044B\\u043B\\u043E\\u0447\\u043D\\u044B\\u0435 \\u0438 \\u0446\\u0438\\u043A\\u043B\\u0438\\u0447\\u0435\\u0441\\u043A\\u0438\\u0435 \\u0441\\u0432\\u044F\\u0437\\u0438 \\u043E\\u0442\\u043A\\u043B\\u043E\\u043D\\u044F\\u044E\\u0442\\u0441\\u044F.\",\"state\":\"Passed\",\"evidence\":[{\"kind\":\"File\",\"path\":\"data/schemas/project-system/task-file-v3.schema.json\"},{\"kind\":\"File\",\"path\":\"src/Electron2D.ProjectSystem/Tasks/TaskBoardV3Validation.cs\"}]},{\"criterionId\":\"negative-contract-tests\",\"description\":\"\\u041D\\u0435\\u0433\\u0430\\u0442\\u0438\\u0432\\u043D\\u044B\\u0435 tests \\u0434\\u043E\\u043A\\u0430\\u0437\\u044B\\u0432\\u0430\\u044E\\u0442 \\u043E\\u0442\\u043A\\u0430\\u0437 \\u0434\\u043B\\u044F \\u043D\\u0435\\u0432\\u043E\\u0437\\u043C\\u043E\\u0436\\
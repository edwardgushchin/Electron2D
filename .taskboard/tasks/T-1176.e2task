  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "cross-column-guard",
      "description": "Drop в другую status column и прежний Alt+Left/Right status move не выполняют status transition; regression, Extension Host, docs, VSIX и taskboard verify проходят.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    },
    {
      "criterionId": "rank-only-dnd",
      "description": "Drag-and-drop внутри effective status column отправляет только rank/group placement mutation; status, task revision и activity не меняются.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    }
  ],

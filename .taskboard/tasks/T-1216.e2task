  "taskUid": "task-e4f2f26cd88e439da3c9a1a80e703d2b",
  "revision": 2,
  "taskId": "T-1216",
  "legacyAliases": [],
  "title": "Восстановить превью v3-вложений VS Code Task Board по taskUid",
  "description": "После перехода TaskBoard v3 корректный compact snapshot содержит `cardPreview`, но установленное VS Code-расширение не показывает обложку. Канонический путь вложения строится по неизменяемому `taskUid` (`.taskboard/attachments/<taskUid>/...`), тогда как Extension Host проверяет allowlisted prefix по отображаемому `taskId` и поэтому удаляет безопасное превью перед отправкой в webview. Нужно использовать доверенный `taskUid` текущего snapshot для owner validation, сохранить traversal/containment boundary и покрыть одинаково compact card preview и изображения в полном окне задачи.",
  "status": "Ready",
  "acceptanceState": "NotSubmitted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0002",
    "tag-0003",
    "tag-0010",
    "tag-0013"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "v3-owner-path",
      "description": "Extension Host принимает корректный растровый путь `.taskboard/attachments/<taskUid>/<attachmentId>/<sha256>.<ext>` только для `taskUid` текущей задачи и создаёт безопасный webview URI для `cardPreview` и attachment preview.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "automatic-preview",
      "description": "При `previewAttachmentId = null` первое растровое вложение из compact snapshot отображается как автоматическая обложка карточки; явный выбор обложки продолжает отображать выбранное изображение.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "path-security",
      "description": "Пути другого `taskUid`, absolute paths, пустые сегменты, `.` и `..` отклоняются; исправление не удаляет owner/containment-проверку и не расширяет webview resource boundary.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "regression-verification",
      "description": "Focused regression сначала воспроизводит отбрасывание v3-превью, затем проходят полный unit-набор, typecheck, сборка VSIX и проверка установленного расширения в реальном VS Code с FFmpeg-снимком карточки.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "documentation",
      "description": "Доменный документ VS Code Task Board до production-кода фиксирует taskUid-based attachment owner boundary, а после GREEN содержит фактическое поведение и команды проверки.",
      "state": "Open",
      "evidence": []
    }
  ],

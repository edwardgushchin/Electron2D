  "executionContract": {
    "taskType": "исправление v3 attachment preview boundary в VS Code Task Board",
    "readyToStart": [
      "Пользовательский снимок после `Developer: Reload Window` подтверждает отсутствие обложки у `T-1212`, хотя `e2d tasks board --compact true` возвращает `cardPreview` A-0001.",
      "Причина локализована: v3 хранит вложения под `taskUid`, а `isSafeAttachmentPath` в Extension Host всё ещё строит allowlisted prefix по `taskId`."
    ],
    "stopConditions": [
      "Исправление требует удалить owner/containment-проверку, разрешить произвольные workspace paths или ослабить webview CSP/resource boundary.",
      "Compact/full task snapshots не предоставляют доверенный `taskUid` либо обнаружено пересечение с незавершённой правкой того же security boundary, которое нельзя безопасно объединить."
    ],
    "allowedChanges": [
      "Доменный документ, типы snapshot при необходимости, `taskForWebview`/`previewForWebview`/`isSafeAttachmentPath` и focused unit-тесты Extension Host.",
      "Сборка и установка VSIX, FFmpeg evidence, taskboard evidence через CLI и append-only дневник."
    ],
    "forbiddenChanges": [
      "Изменение canonical attachment layout, `taskUid`, blob-файлов или taskboard storage вне штатного CLI.",
      "Отключение проверки безопасного пути, разрешение внешних URI, несвязанный рефакторинг webview или изменение выбора обложки."
    ],
    "requiredOutputs": [
      "TaskUid-aware owner validation для compact `cardPreview` и полных attachment previews.",
      "Негативные проверки foreign owner/traversal и RED/GREEN регрессия автоматической обложки.",
      "Синхронизированный доменный документ, установленный VSIX и реальный FFmpeg-снимок карточки с обложкой."
    ],

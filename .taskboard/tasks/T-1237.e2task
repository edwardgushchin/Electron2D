  "executionContract": {
    "taskType": "действие возврата на доработку в потоке человеческой приёмки VS Code Task Board",
    "readyToStart": [
      "Родительская задача T-1147 принята, а текущая реализация T-1209 показывает в footer задачи Review только кнопку «Принять».",
      "Публичная операция request-changes и доверенный human-decision bridge уже сохраняют непустую причину в AcceptanceResult; реализация начинается с обновления docs/editor/project-tasks-board.md и падающих тестов."
    ],
    "stopConditions": [
      "Изменение требует ослабить trusted-human capability, разрешить webview или обычному агенту напрямую принимать решение либо передавать полномочие через argv.",
      "Причину можно сохранить только ручной правкой .taskboard, отдельной неконтекстной заметкой или потерей исходной immutable activity.",
      "Возврат из InternalReview невозможно выполнить revision-aware через существующий submit/request-changes workflow без изменения канонической модели приёмки."
    ],
    "allowedChanges": [
      "Доменный документ VS Code Task Board и уточнение существующего контракта контекста задачи.",
      "Footer, стили, локализация, typed webview messages, Extension Host orchestration и существующий trusted CLI bridge в src/Electron2D.VsCode.",
      "Целевые unit/Extension Host/.NET integration tests, generated docs index, устанавливаемый VSIX, локальный FFmpeg-артефакт, task activity и append-only дневник."
    ],
    "forbiddenChanges": [
      "Ручное редактирование .taskboard, ослабление schema/transition/CAS validation или добавление второго writer для задач.",
      "Автоматический возврат без явного непустого ввода и подтверждения пользователя либо подмена причины заранее заданной строкой.",
      "Изменение статусов, принятие или возврат посторонних задач, несвязанный рефакторинг доски и визуальная проверка только на fixture/headless render."
    ],
    "requiredOutputs": [
      "Две локализованные кнопки решения в footer Review-задачи и нативное обязательное поле причины возврата.",
      "Revision-aware workflow InternalReview/Submitted → InProgress/ChangesRequested через существующий trusted-human bridge с каноническим refresh и fail-closed errors.",
      "Доказательство сохранения причины в AcceptanceResult и data.agentContext.activity, синхронизированные документы и тесты, собранный VSIX и FFmpeg-снимок реального окна."
    ],

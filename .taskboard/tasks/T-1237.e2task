  "revision": 1,
  "taskId": "T-1237",
  "legacyAliases": [],
  "title": "Добавить «Вернуть на доработку» в приёмку задачи",
  "description": "В нижней панели Task Details для задачи со статусом Review рядом с зелёной кнопкой «Принять» нужно показать второе действие — «Вернуть на доработку». Нажатие открывает нативное окно VS Code для обязательного ввода причины; отмена или пустой текст не меняют задачу. После подтверждения Extension Host использует существующий доверенный канал человеческого решения и актуальную ревизию: при необходимости сначала переводит внутреннюю проверку в Submitted, затем выполняет request-changes, возвращает задачу в InProgress и перечитывает каноническое состояние. Введённая причина должна без подмены шаблонным текстом сохраниться в immutable AcceptanceResult, отображаться в активности и входить в data.agentContext.activity при следующем e2d tasks get, чтобы исполнитель получил её как часть контекста задачи. Это продолжение T-1209: кнопка «Принять» и её ограничения сохраняются, но единственное действие приёмки заменяется явным выбором принять или вернуть результат.",
  "status": "Ready",
  "acceptanceState": "NotSubmitted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0002",
    "tag-0003",
    "tag-0009"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "review-footer-actions",
      "description": "Нижняя панель активной задачи со статусом Review показывает две доступные с клавиатуры локализованные кнопки: вторичную «Вернуть на доработку» и зелёную «Принять» справа; в других статусах новое действие не появляется, а существующие ограничения кнопки «Принять» сохраняются.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "required-rework-reason",
      "description": "Нажатие «Вернуть на доработку» открывает нативное поле ввода с понятной русской подписью и обязательной непустой причиной. Отмена окна или строка из пробелов не запускает submit, request-changes и локальное изменение интерфейса.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "trusted-return-workflow",
      "description": "После ввода и подтверждения причины Extension Host в общей сериализованной очереди использует trusted-human bridge: для InternalReview сначала выполняет submit и передаёт полученную ревизию в request-changes, а для Submitted не повторяет submit. Успех переводит задачу в InProgress с acceptanceState ChangesRequested и обновляет интерфейс только после канонического чтения; conflict и другие ошибки показываются стандартным уведомлением VS Code.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "reason-in-agent-context",
      "description": "Введённая пользователем причина сохраняется в канонической записи AcceptanceResult с decision ChangesRequested, видна во вкладке «Активность» и возвращается командой e2d tasks get в data.canonicalTask.activity и data.agentContext.activity, поэтому следующая работа агента получает замечание в контексте задачи.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "regression-and-real-window-proof",
      "description": "RED/GREEN тесты покрывают обе кнопки, локализацию, обязательный ввод, отмену, allowlist сообщения, оба состояния Review, передачу точной причины и её присутствие в agentContext. Полный набор unit-тестов, typecheck, Extension Host tests, сборка VSIX, проверки документации и FFmpeg-снимок установленного расширения подтверждают результат в реальном окне VS Code.",
      "state": "Open",
      "evidence": []
    }
  ],

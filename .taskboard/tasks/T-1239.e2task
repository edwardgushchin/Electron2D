  "executionContract": {
    "taskType": "сквозное исправление presentation contract для Activity VS Code Task Board",
    "readyToStart": [
      "Родительская T-1147 принята; T-1222 содержит реальное воспроизведение WorkspaceChangesUpdated с сырым JSON.",
      "T-1157 и T-1232 документируют точечные исправления StatusChange и TaskPatched, поэтому RED должен проверять полноту всех видов по машинной схеме."
    ],
    "stopConditions": [
      "Исправление требует заменить канонический payload локализованным текстом, изменить TaskBoard v3 schema или lifecycle задач.",
      "Невозможно синхронизировать покрытие с единым машинно-читаемым перечнем видов и завершать проверку fail closed.",
      "Fallback по-прежнему выводит сырой JSON/HTML либо системность определяется только личностью автора."
    ],
    "allowedChanges": [
      "Связанные доменные документы и generated documentation index.",
      "VS Code model, activity registry/parser, webview, localization, CSS, unit и Extension Host тесты.",
      "Schema-to-presenter contract test, VSIX и FFmpeg evidence, task activity и append-only дневник."
    ],
    "forbiddenChanges": [
      "Изменение канонического payload, schema, lifecycle или исторических activity.",
      "Точечная ветка только для WorkspaceChangesUpdated без общего исчерпывающего контракта.",
      "Ручное редактирование .taskboard, несвязанный рефакторинг и fixture-only визуальная приёмка."
    ],
    "requiredOutputs": [
      "Типизированный исчерпывающий реестр представления каждого канонического вида activity.",
      "Читаемое WorkspaceChangesUpdated, семантический системный фильтр и безопасный fallback без сырого JSON.",
      "RED/GREEN schema-to-presenter regression, проверенный VSIX и FFmpeg evidence реального окна VS Code."
    ],

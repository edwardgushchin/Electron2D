  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "typed-activity-presentation-registry",
      "description": "Модель разбирает kind на границе данных и использует единый типизированный реестр presenter для каждого канонического вида activity; прежние Comment и AgentSummary после миграции также имеют явное представление.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "localized-human-summaries",
      "description": "Для каждого вида события определены ru/en название, безопасная краткая сводка и поисковый текст; WorkspaceChangesUpdated показывает число и виды затронутых файлов без digest, revision и сырого JSON.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "semantic-system-filtering",
      "description": "Признак системного события определяется семантикой вида/metadata presenter, а не только actorKind; WorkspaceChangesUpdated скрывается при выключенном переключателе «Системные».",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "safe-fallback-and-canonical-payload",
      "description": "Неизвестный вид или некорректный payload не выводит сырой JSON, HTML либо escape-последовательности в основной ленте; канонический технический payload не изменяется и остаётся доступен для аудита/CLI или явного раскрытия деталей.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "exhaustive-schema-contract",
      "description": "Автоматический тест читает enum видов activity из task-file-v3.schema.json и требует точного покрытия реестром, парсерами и локализациями; новый вид без presenter гарантированно завершает проверку RED.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "regression-and-real-window-proof",
      "description": "Unit и Extension Host regressions покрывают все виды, поиск, системный фильтр и fallback; VSIX проходит упаковку, а FFmpeg-запись реального окна VS Code на T-1222 подтверждает читаемое WorkspaceChangesUpdated без сырого JSON.",
      "state": "Open",
      "evidence": []
    }
  ],

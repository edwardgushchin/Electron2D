{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-713b2284fc5d4745983e632c61a230e9",
  "revision": 28,
  "taskId": "T-1230",
  "legacyAliases": [],
  "title": "Показывать сообщения Codex как Agent в активности VS Code",
  "description": "Во вкладке «Активность» сообщения агента должны иметь единую пользовательскую подпись `Agent` и узнаваемый значок Codex вместо буквы из actorId. Пока Task Board поддерживает только провайдера Codex, поэтому новые записи с actorKind `Agent` и сохранённые до появления canonical agent provenance записи `Cli / cli` получают одну presentation-модель без изменения append-only истории. Записи человека и других системных участников сохраняют собственные подписи и обычные буквенные аватары. Архитектура представления должна оставлять отдельную точку выбора провайдера для будущей настройки, но текущий интерфейс не добавляет саму настройку.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0002",
    "tag-0003",
    "tag-0010",
    "tag-0017",
    "tag-0018"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "agent-label",
      "description": "Новые записи с actorKind `Agent` и legacy-записи `Cli / cli` отображаются с подписью `Agent`; сырые подписи `Agent / Codex` и `cli` для этих записей в интерфейсе не показываются.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "Attachment",
          "attachmentId": "A-0001"
        }
      ]
    },
    {
      "criterionId": "codex-avatar",
      "description": "У сообщения текущего агента показан theme-compatible SVG-знак Codex с доступным названием, а буквенный аватар `C` для него не создаётся.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "Attachment",
          "attachmentId": "A-0001"
        }
      ]
    },
    {
      "criterionId": "legacy-visible",
      "description": "Legacy-записи `Cli / cli`, распознанные как сообщения Codex, не скрываются переключателем системных событий и видны в обычной временной шкале.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/webview-layout.test.ts"
        }
      ]
    },
    {
      "criterionId": "other-actors",
      "description": "Записи человека и иных участников не переименовываются в Agent и продолжают использовать безопасную подпись и буквенный аватар из canonical actor identity.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/webview-layout.test.ts"
        }
      ]
    },
    {
      "criterionId": "verification",
      "description": "Доменный документ обновлён до production-кода; focused regression проходит RED→GREEN, затем успешны полный unit-набор, typecheck, Extension Host, VSIX package/install и визуальная проверка реального окна VS Code через FFmpeg helper.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "Attachment",
          "attachmentId": "A-0001"
        },
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/webview-layout.test.ts"
        },
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    }
  ],

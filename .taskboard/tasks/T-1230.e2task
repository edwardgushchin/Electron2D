  "executionContract": {
    "taskType": "Представление сообщений текущего агента в журнале активности VS Code Task Board",
    "readyToStart": [
      "Canonical activity snapshot уже содержит actorId и actorKind, а webview централизованно формирует подпись и аватар каждой записи.",
      "Текущий продукт поддерживает одного провайдера агента — Codex; настройка выбора провайдера в эту задачу не входит.",
      "Изменение начинается с обновления доменного документа и наблюдаемого RED regression."
    ],
    "stopConditions": [
      "Для изменения интерфейса потребуется переписать или мигрировать append-only activity history.",
      "Нельзя надёжно сохранить отличимость человеческих записей от агентских на уровне canonical actorKind.",
      "Значок потребует сетевой загрузки или небезопасного HTML в webview."
    ],

                "path:src/Electron2D.VsCode/test/suite/index.ts",
                "path:src/Electron2D.VsCode/artifacts/**",
                "path:data/documentation/**"
              ],
              "forbiddenChanges": [
                "Перезапись actorId, actorKind или существующих append-only activity entries.",
                "Добавление выбора провайдера в настройки или поддержка провайдера кроме Codex.",
                "Несвязанные изменения других вкладок, canonical task schema, conversation или audit contracts."

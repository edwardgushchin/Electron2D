{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-a4ce3764302d451f84438ac015cf86b8",
  "revision": 36,
  "taskId": "T-1212",
  "legacyAliases": [],
  "title": "Сделать ширину колонок VS Code Task Board адаптивной в пределах min/max",
  "description": "Шесть видимых статусных колонок VS Code Task Board должны иметь адаптивную ширину. Текущее значение `calc(13.25rem + 10px)` становится минимальной шириной одной колонки: сильнее сжимать колонку нельзя, а при недостатке места сохраняется горизонтальная прокрутка. Если доступная ширина board viewport больше суммарного минимума шести колонок с текущими gap и padding, все шесть колонок равномерно расширяются и вместе заполняют доступную ширину. Рост каждой колонки ограничен максимумом `20rem`; на более широком viewport колонки перестают расширяться. Высота по содержимому, расстояние между колонками, card containment, порядок и lifecycle не меняются.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P2",
  "tagIds": [
    "tag-0001",
    "tag-0002",
    "tag-0003",
    "tag-0010",
    "tag-0017"
  ],
  "deadline": null,
  "createdBy": "cli",
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "minimum-column-width",
      "description": "Каждая из шести статусных колонок имеет минимальную ширину `calc(13.25rem + 10px)` и никогда не сжимается ниже неё; при более узком viewport доступна горизонтальная прокрутка.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-t1212-narrow.png"
        }
      ]
    },
    {
      "criterionId": "fluid-viewport-fill",
      "description": "Между минимальным и максимальным порогами все шесть колонок расширяются равномерно и вместе с неизменными gap/padding заполняют всю доступную ширину board viewport без пустой полосы справа.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-t1212-fluid.png"
        }
      ]
    },
    {
      "criterionId": "maximum-column-width",
      "description": "Ширина одной статусной колонки не превышает `20rem`; на сверхшироком viewport колонки прекращают расширяться и сохраняют одинаковую ширину.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-t1212-wide-max.png"
        }
      ]
    },
    {
      "criterionId": "layout-preserved",
      "description": "Высота колонок по содержимому, текущий gap, card containment, общая вертикальная прокрутка, horizontal scrollbar при необходимости и порядок шести статусов сохраняются.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/webview-layout.test.ts"
        }
      ]
    },
    {
      "criterionId": "responsive-verification",
      "description": "RED/GREEN layout regressions и реальная проверка установленного VSIX подтверждают три режима: узкий viewport с минимальной шириной и scroll, средний viewport с равномерным заполнением, широкий viewport с ограничением `20rem`.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    }
  ],

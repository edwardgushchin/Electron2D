  "executionContract": {
    "taskType": "адаптивная min/fluid/max ширина статусных колонок VS Code Task Board",
    "readyToStart": [
      "Пользователь изменил ранее проверенный fixed-width контракт: `calc(13.25rem + 10px)` теперь является минимумом, а не постоянной шириной.",
      "Доска отображает ровно шесть внешних статусных колонок; compact/full task data, карточки и lifecycle не требуют изменений."
    ],
    "stopConditions": [
      "Адаптивное заполнение требует сжимать колонку ниже минимума, превышать `20rem`, менять gap/padding, ширину карточки независимо от колонки или число/порядок статусов.",
      "Обновлённый пакет невозможно проверить в реальном VS Code на узком, среднем и широком viewport через обязательный FFmpeg-захват окна."
    ],
    "allowedChanges": [
      "Ожидаемый и фактический контракт в доменном документе, focused responsive layout tests и CSS grid sizing/status column width rules.",
      "Сгенерированный индекс документации, устанавливаемый VSIX, task activity и append-only дневник.",
      "path:docs/editor/project-tasks-board.md",
      "path:src/Electron2D.VsCode/src/webview.css",
      "path:src/Electron2D.VsCode/test/unit/webview-layout.test.ts",
      "path:data/dev-diary/**",
      "path:src/Electron2D.VsCode/.vscode-test/user-data/**",
      "path:src/Electron2D.VsCode/dist/**",
      "path:src/Electron2D.VsCode/src/cli.ts",
      "path:src/Electron2D.VsCode/src/extension.ts",
      "path:src/Electron2D.VsCode/src/localization.ts",
      "path:src/Electron2D.VsCode/test/unit/cli.test.ts",
      "path:src/Electron2D.VsCode/test/suite/index.ts",
      "path:src/Electron2D.VsCode/artifacts/**",
      "path:data/documentation/**"
    ],
    "forbiddenChanges": [
      "Изменение высоты колонок, gap/padding доски, ширины карточек отдельно от родителя, статусов, порядка задач, modal details или taskboard data.",
      "Ручное редактирование `.taskboard`, несвязанный рефакторинг webview или изменение CLI-контракта."
    ],
    "requiredOutputs": [
      "Минимальная ширина `calc(13.25rem + 10px)`, равномерное заполнение viewport шестью колонками и максимальная ширина `20rem`.",
      "Регрессионные проверки трёх responsive-режимов и сохранённых scrolling/containment правил.",
      "Синхронизированный доменный документ, собранный VSIX и реальные FFmpeg-снимки узкого, среднего и широкого viewport."
    ],

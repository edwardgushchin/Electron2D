        "hashProfile": "sha256-jcs-rfc8785-v1",
        "patch": [
          {
            "op": "replace",
            "path": "/executionContract",
            "oldValue": {
              "taskType": "Исправление отображения растровой обложки карточки VS Code Task Board",
              "readyToStart": [
                "Пользовательский снимок показывает горизонтальное кадрирование широкого изображения в карточке.",
                "Существующий безопасный выбор растрового вложения и `cardPreview` уже работают; замечание относится только к presentation layout.",
                "Изменение начинается с доменного документа и наблюдаемого RED regression."
              ],
              "stopConditions": [
                "Исправление потребует ослабить raster allowlist, containment path или CSP.",
                "Исправление потребует изменить canonical данные вложений, выбор обложки или lifecycle задачи.",
                "Обнаружено несовместимое пересечение с незавершённой правкой тех же CSS-правил карточки."
              ],
              "allowedChanges": [
                "Presentation contract и проверочная документация обложки карточки.",
                "Focused layout regression и минимальные стили `.task-card-cover`.",
                "Собранный VSIX, generated documentation index, task activity и append-only дневник.",
                "path:src/Electron2D.VsCode/**",
                "path:docs/editor/project-tasks-board.md",
                "path:data/documentation/**",
                "path:data/dev-diary/**"
              ],
              "forbiddenChanges": [
                "Canonical TaskBoard schema, модель вложений, Extension Host URI validation и выбор preview attachment.",
                "Небезопасные URI, HTML/SVG preview, `innerHTML`, внешние ресурсы или literal color palette.",
                "Несвязанный рефакторинг карточек, колонок, Task Details или lifecycle.",
                "path:data/schemas/**",
                "path:src/Electron2D.ProjectSystem/**"
              ],
              "requiredOutputs": [
                "Весь безопасный растр масштабируется до ширины карточки с сохранением пропорций и без горизонтального кадрирования.",
                "Карточка и изображение не выходят за ширину статусной колонки; текстовая часть остаётся ниже обложки.",
                "RED/GREEN regression, полный unit/typecheck, собранный VSIX и проверенный FFmpeg-снимок реального VS Code."
              ],
              "commands": [
                {
                  "commandId": "cover-unit",
                  "kind": "Process",
                  "executable": "npm",
                  "arguments": [
                    "--prefix",
                    "src/Electron2D.VsCode",
                    "run",
                    "test:unit"

{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-54c951c6aed54731b49a7f10b40ec62d",
  "revision": 47,
  "taskId": "T-1199",
  "legacyAliases": [],
  "title": "Показывать превью изображения на карточке задачи",
  "description": "Показывать на карточке задачи обложку из прикреплённых изображений. Если пользователь ничего не выбирал, использовать первое безопасное растровое вложение. В окне задачи разрешить назначить любое прикреплённое изображение обложкой или вернуть автоматический выбор. При удалении выбранного изображения автоматически перейти к первому оставшемуся. Не считать связанные файлы вложениями и не показывать SVG, HTML, архивы или небезопасные пути. Обновить модель и схемы TaskManager, CLI compact response, VS Code Task Board, русскую и английскую локализацию, документацию и тесты. Проверить собранное расширение в реальном VS Code через обязательный FFmpeg-захват.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0009"
  ],
  "deadline": null,
  "createdBy": "cli",
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "compact-and-secure-uri",
      "description": "Компактный снимок передаёт только метаданные эффективной обложки, а Extension Host преобразует проверенный путь вложения в webview URI; произвольные пути и неподдерживаемые media types не попадают в карточку.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs"
        }
      ]
    },
    {
      "criterionId": "default-image-preview",
      "description": "Если обложка не выбрана, карточка показывает первое безопасное растровое вложение; задача без изображений не получает пустого места под обложку. Изображение целиком масштабируется до доступной ширины карточки с сохранением пропорций, не обрезается по горизонтали и не выходит за границы.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "src/Electron2D.VsCode/test/unit/webview-layout.test.ts"
        }
      ]
    },
    {
      "criterionId": "selected-preview-contract",
      "description": "Задача хранит необязательную ссылку на выбранное изображение. CLI позволяет назначить или сбросить обложку, отклоняет отсутствующие и нерастровые вложения, а удаление выбранного файла возвращает автоматический выбор.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs"
        }
      ]
    },
    {
      "criterionId": "task-details-selection",
      "description": "Во вкладке файлов можно увидеть текущую обложку, назначить другое изображение и вернуть автоматический выбор; элементы доступны с клавиатуры и локализованы на русский и английский.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",

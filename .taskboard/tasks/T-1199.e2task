                  "workingDirectory": ".",
                  "platforms": [
                    "Any"
                  ],
                  "timeoutSeconds": 300,
                  "expectedExitCodes": [
                    0
                  ],
                  "requestedCapabilities": [
                    "WorkspaceRead"
                  ],
                  "confirmation": "PolicyDecides"
                },

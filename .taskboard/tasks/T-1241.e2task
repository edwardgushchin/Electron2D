  "executionContract": {
    "taskType": "массовая актуализация канонических контрактов задач Task Board",
    "readyToStart": [
      "Пользователь явно поручил актуализировать весь набор по тегу `Task Board`.",
      "Родительская T-1147 принята; taskboard v3 проходит текущую проверку.",
      "Перед каждой mutation выполняется свежий canonical read и optimistic revision check."
    ],
    "stopConditions": [
      "Для конкретной задачи отсутствует достаточное доказательство реализации или актуального результата.",
      "Обновление потребует подделать human acceptance, переписать immutable history или править `.taskboard` вручную.",
      "Аудит обнаружит реальный product defect, который нельзя честно закрыть одной актуализацией task contract."
    ],
    "allowedChanges": [
      "Канонические definition, criteria, typed evidence, conversation и lifecycle активных задач с `tag-0001` через `e2d tasks`.",
      "Append-only дневник и временные аудит-отчёты под `.temp`.",
      "path:data/dev-diary/2026/07 Июль/14-07-2026.md",
      "path:data/dev-diary/**",
      "path:src/Electron2D.VsCode/.vscode-test/user-data/**",
      "path:src/Electron2D.VsCode/dist/**",
      "path:src/Electron2D.VsCode/src/cli.ts",
      "path:src/Electron2D.VsCode/src/extension.ts",
      "path:src/Electron2D.VsCode/src/localization.ts",

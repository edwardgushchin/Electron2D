      "path:src/Electron2D.VsCode/test/suite/index.ts",
      "path:src/Electron2D.VsCode/artifacts/**",
      "path:data/documentation/**",
      "path:docs/editor/project-tasks-board.md"
    ],
    "forbiddenChanges": [
      "Прямое редактирование `.e2task`/`.e2tasks`, удаление history и обход validators.",
      "Human accept, archive, commit или push без отдельного явного запроса.",
      "Изменение production-кода, тестов или доменных документов под видом task normalization без отдельного feature-gate цикла."
    ],
    "requiredOutputs": [
      "Полная инвентаризация всех активных задач с tag `Task Board` и классификация каждого lifecycle/contract состояния.",
      "Revision-aware актуализация всех доказанно исторических Review-задач с сохранением будущего backlog и terminal lifecycle.",
      "Финальный машинно-проверяемый аудит набора и taskboard без пустых или противоречащих текущему продукту контрактов."
    ],

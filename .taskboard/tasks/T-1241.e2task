  "taskUid": "task-262f701399684038850d39554d93b60b",
  "revision": 17,
  "taskId": "T-1241",
  "legacyAliases": [],
  "title": "Привести все задачи с тегом Task Board к актуальному контракту",
  "description": "Все активные задачи, которым назначен общий тег `Task Board`, должны описывать действующий контракт продукта и быть пригодны для канонического lifecycle TaskBoard v3. Исторически завершённые задачи в `Review` нужно сверить с текущим доменным документом, реализацией, тестами и сохранёнными сообщениями: устаревшие требования заменить актуальными результатами, добавить typed evidence и передать на пользовательскую приёмку только при достаточном доказательстве. Будущие задачи в `Ready` нельзя объявлять выполненными; принятые и отменённые задачи сохраняют lifecycle и immutable историю.\n\nИтоговый аудит должен охватить весь набор по стабильному `tag-0001`, включая эту задачу, и доказать отсутствие пустых критериев, неподтверждённых `Passed` и исторических требований, которые противоречат текущей модели VS Code Task Board. Все изменения выполняются только через revision-aware `e2d tasks` без прямого редактирования `.taskboard`.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0018",
    "tag-0013",
    "tag-0026",
    "tag-0029"
  ],
  "deadline": null,

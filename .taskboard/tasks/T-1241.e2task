  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "complete-tagged-inventory",
      "description": "Канонический snapshot перечисляет каждую активную задачу с `tag-0001`; для каждой зафиксированы lifecycle, прогресс критериев и класс актуальности, а архивный scope проверен отдельно.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "data/dev-diary/2026/07 Июль/14-07-2026.md"
        }
      ]
    },
    {
      "criterionId": "historical-review-contracts",
      "description": "Каждая исторически завершённая задача в `Review` имеет актуальное русское описание, непустой проверяемый набор критериев, typed evidence и структурированный execution contract; старые сообщения сохраняются только как история.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "data/dev-diary/2026/07 Июль/14-07-2026.md"
        }
      ]
    },
    {
      "criterionId": "superseded-behavior-aligned",
      "description": "Требования, изменённые более поздними задачами, явно приведены к действующему UI и lifecycle: шесть статусов, локализованные названия, актуальные details/activity/actions и TaskBoard v3 без возврата устаревших поверхностей.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    },
    {
      "criterionId": "lifecycle-preserved",
      "description": "Задачи будущей работы остаются открытыми в `Ready`, отменённые и принятые сохраняют terminal lifecycle, а `Review/Submitted` используется только для полностью доказанных результатов; ложная human acceptance не создаётся.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/project-system/project-task-manager.md"
        }
      ]
    },
    {
      "criterionId": "machine-contract-complete",
      "description": "У каждой задачи набора есть связные typed links и применимый execution contract с readiness, stop conditions, областями изменений, ожидаемыми результатами и проверками либо сохранённый terminal-контракт, уже доказанный приёмкой.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs"
        }
      ]
    },
    {
      "criterionId": "full-audit-verification",
      "description": "Повторный полный аудит не находит задач с тегом `Task Board`, которые нарушают актуальные invariants; `e2d tasks verify` и `git diff --check` проходят без ошибок.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "data/dev-diary/2026/07 Июль/14-07-2026.md"
        }
      ]
    }
  ],

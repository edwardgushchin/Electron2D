  "executionContract": {
    "taskType": "исправление рассинхронизации счётчика блокеров карточки VS Code Task Board",
    "readyToStart": [
      "Пользовательский сценарий воспроизведён на T-1198: общее число dependency relations остаётся равным четырём, хотя число незавершённых зависимостей уменьшается.",
      "Текущий webview явно использует `task.dependencies.length || 1`, а compact snapshot не содержит отдельного количества активных причин блокировки.",
      "Перед production-кодом доменные документы фиксируют точную семантику `activeBlockerCount`, после чего добавляются RED regression tests."
    ],
    "stopConditions": [
      "Для исправления требуется изменить канонические правила status, readiness, dependency graph или blocker lifecycle вместо добавления вычисляемой проекции.",
      "Нельзя однозначно сопоставить цифру с текущим списком активных причин без изменения публичного taskboard snapshot contract.",
      "Реальный watcher refresh не воспроизводит обновление карточки и требует отдельного продуктового решения по доставке snapshot."
    ],
    "allowedChanges": [
      "Проекция активных причин блокировки в Project Tasks CLI/ProjectSystem, типизированная VS Code model, card renderer, связанные тесты и два доменных документа.",
      "Generated docs index, VSIX/runtime outputs, task activity/evidence, FFmpeg-артефакт и append-only дневник.",
      "path:docs/editor/project-tasks-board.md",
      "path:docs/project-system/project-task-manager.md",
      "path:src/Electron2D.Cli/ProjectTasksCli.cs",
      "path:src/Electron2D.ProjectSystem/Tasks/ProjectTasks.cs",
      "path:src/Electron2D.ProjectSystem/Tasks/TaskBoardV3DiskStore.cs",
      "path:src/Electron2D.VsCode/src/model.ts",
      "path:src/Electron2D.VsCode/src/webview.ts",
      "path:src/Electron2D.VsCode/src/localization.ts",
      "path:src/Electron2D.VsCode/test/unit/webview-layout.test.ts",
      "path:src/Electron2D.VsCode/test/suite/index.ts",
      "path:tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs",
      "path:tests/Electron2D.Tests.Integration/ProjectTaskManagerTests.cs",
      "path:src/Electron2D.VsCode/dist/**",
      "path:src/Electron2D.VsCode/artifacts/electron2d-taskboard.vsix",
      "path:src/Electron2D.VsCode/.vscode-test/**",
      "path:data/documentation/**",
      "path:data/dev-diary/**",
      "path:.taskboard/**",
      "path:.temp/taskboard-blocker-count-*.png"
    ],
    "forbiddenChanges": [
      "Изменение canonical status, `boardStatus`, readiness, dependency relations, explicit blocker lifecycle или правил размещения по колонкам.",
      "Подсчёт общего количества dependency relations, искусственный fallback `|| 1`, клиентский кэш счётчика или отдельный polling/timer.",
      "Прямое редактирование `.taskboard`, использование Unicode/icon font вместо существующего SVG или несвязанный рефакторинг Task Board."
    ],
    "requiredOutputs": [
      "Документированная вычисляемая проекция `activeBlockerCount` для compact и full taskboard snapshot.",
      "Карточка, чей счётчик уменьшается вместе с актуальным списком активных причин после штатного refresh.",
      "RED/GREEN integration и unit regressions для dependency и explicit blocker combinations.",
      "Зелёные typecheck, Extension Host, VSIX, docs/license checks и проверенный FFmpeg-снимок реального окна VS Code."
    ],

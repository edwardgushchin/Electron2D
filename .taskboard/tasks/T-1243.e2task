  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "canonical-active-blocker-count",
      "description": "Compact и full taskboard snapshots содержат `activeBlockerCount`, равный сумме незавершённых или отменённых зависимостей и explicit blockers со `state=Active`; завершённые зависимости и resolved blockers в число не входят.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "card-uses-canonical-count",
      "description": "Красный индикатор заблокированной карточки показывает `activeBlockerCount` и не использует `task.dependencies.length`, `|| 1` или другой клиентский fallback; tooltip и доступное имя остаются локализованными.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "count-shrinks-after-refresh",
      "description": "После каждого штатного watcher/command refresh завершение зависимостей или разрешение explicit blocker уменьшает число без перезапуска панели; регрессия на четырёх зависимостях подтверждает последовательность `4 → 3 → 2 → 1 → 0` и возврат Ready-задачи из колонки «Заблокировано» при снятии последней причины.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "mixed-blocker-semantics",
      "description": "Тесты покрывают смешанные причины: незавершённые, отменённые и завершённые зависимости, несколько active/resolved explicit blockers и явно заблокированную задачу; цифра совпадает с актуальным списком активных причин во всех случаях.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "lifecycle-unchanged",
      "description": "Исправление не меняет canonical status, `boardStatus`, readiness, dependency relations, blocker lifecycle и порядок карточек; существующий SVG, цвет темы и геометрия footer сохраняются.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "regression-and-real-window-proof",
      "description": "Доменный документ, C# integration tests и VS Code unit/Extension Host tests зафиксировали новую семантику; typecheck, VSIX package, docs/license verifiers и проверенный FFmpeg-снимок реального окна VS Code проходят.",
      "state": "Open",
      "evidence": []
    }
  ],

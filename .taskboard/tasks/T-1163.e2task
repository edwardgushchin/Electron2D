{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-cd55f0aea5514642bdd395311cc6fc52",
  "revision": 15,
  "taskId": "T-1163",
  "legacyAliases": [],
  "title": "Выровнять левый край VS Code Task Board",
  "description": "## Контекст\n\nНа пользовательском screenshot первая status column сдвинута вправо относительно title/breadcrumb. Причина — `.board { scrollbar-gutter: stable both-edges; }`: Chromium резервирует симметричный gutter для вертикального scrollbar справа и добавляет ненужный такой же gutter слева.\n\n## Критерии приёмки\n\n- Board использует односторонний `scrollbar-gutter: stable`, сохраняя стабильное место под scrollbar только справа.\n- Первая колонка визуально выровнена с левой границей header content и не получает дополнительный левый scrollbar gutter.\n- Горизонтальный и вертикальный scroll, фиксированная ширина колонок и modal overlay не регрессируют.\n- Unit layout, typecheck, Extension Host, VSIX package/install, docs/licenses/taskboard verify проходят.\n\n## Execution contract\n\nМенять только VS Code board layout CSS/test, `docs/editor/project-tasks-board.md`, task evidence и append-only diary. Не менять TaskManager или task files вручную.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0011",
    "tag-0017",
    "tag-0018"
  ],
  "deadline": null,
  "createdBy": "cli",
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "left-edge-alignment",
      "description": "Board использует scrollbar-gutter: stable без both-edges; первая колонка не получает дополнительный левый gutter и сохраняет рабочий horizontal/vertical scroll.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/editor/project-tasks-board.md"
        }
      ]
    }
  ],

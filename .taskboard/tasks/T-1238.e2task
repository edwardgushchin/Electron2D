{
  "format": "Electron2D.TaskFile",
  "version": 3,
  "boardId": "main",
  "taskUid": "task-35f1858cc4054686b5b7c26b80b9be63",
  "revision": 25,
  "taskId": "T-1238",
  "legacyAliases": [],
  "title": "Исправить перезапись context checkpoints при структурированном обновлении задачи",
  "description": "Структурированная команда e2d tasks update для задачи с уже сохранённым context checkpoint может завершаться ошибкой неизменяемого prefix, даже когда пользователь меняет только разрешённые поля вроде критериев или executionContract. Дефект воспроизведён на T-1222: после checkpoint в задаче появилась новая activity, затем ApplyStructuredTaskInput вызвал TaskBoardV3Compatibility.UpgradeTask, который безусловно заменил сохранённый checkpoint.lastActivitySequence текущим корневым значением. Transition validator правильно заблокировал попытку переписать историю. Нужно исправить compatibility/update path так, чтобы канонические checkpoints сохранялись без изменений, а однозначное заполнение отсутствующего legacy-поля выполнялось только для действительно старого draft. Строгая проверка append-only prefix должна остаться: настоящее изменение существующего checkpoint по-прежнему отклоняется. После исправления revision-aware structured update изменяет только запрошенные definition-поля, добавляет обычную TaskPatched activity и не требует ручной правки .taskboard.",
  "status": "Done",
  "acceptanceState": "Accepted",
  "priority": "P1",
  "tagIds": [
    "tag-0001",
    "tag-0008",
    "tag-0010",
    "tag-0018",
    "tag-0020"
  ],
  "deadline": null,
  "createdBy": "cli",
  "assignee": null,
  "parentTaskUid": "task-b59811a17c316e5dc21abf6970f1f24c",
  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "checkpoint-update-red",
      "description": "Целевой RED-тест создаёт задачу с каноническим context checkpoint, добавляет после него новую activity и воспроизводит ложный immutable-prefix failure при структурированном update разрешённого definition-поля.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs"
        }
      ]
    },
    {
      "criterionId": "canonical-prefix-preserved",
      "description": "После исправления структурированное обновление задачи с историческим checkpoint завершается успешно: существующий массив contextCheckpoints и все поля каждого сохранённого checkpoint остаются неизменными, меняются только запрошенные definition-поля, revision и штатно добавленная TaskPatched activity.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/Electron2DCliWorkflowTests.cs"
        }
      ]
    },
    {
      "criterionId": "legacy-upgrade-narrowed",
      "description": "Compatibility-upgrade однозначно добавляет lastActivitySequence только checkpoint старого draft, где поле действительно отсутствует, и никогда не синхронизирует уже сохранённое значение с текущим корневым watermark. Повторный upgrade канонического документа идемпотентен.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs"
        }
      ]
    },
    {
      "criterionId": "tampering-still-rejected",
      "description": "Transition validator продолжает отклонять удаление, перестановку и любое содержательное изменение существующего checkpoint; исправление не ослабляет append-only prefix, schema validation, context digest или CAS-защиту.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "tests/Electron2D.Tests.Integration/TaskBoardV3ContractTests.cs"
        }
      ]
    },
    {
      "criterionId": "cli-regression-and-docs",
      "description": "CLI-регрессия на эквиваленте T-1222 подтверждает успешный e2d tasks update --input и неизменный checkpoint-prefix. Доменный и CLI-контракты синхронизированы; focused tests, сборка, docs checks, license verifier, taskboard verify и whitespace check проходят.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "docs/cli/e2d-cli.md"
        }
      ]
    }
  ],

  "relations": [],
  "acceptanceCriteria": [
    {
      "criterionId": "complete-submitted-inventory",
      "description": "Все задачи Task Board в Review/Submitted проверены по машинному инварианту allowedChanges.Any(path:<glob>), а исходный и итоговый counts зафиксированы.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": "data/dev-diary/2026/07 Июль/14-07-2026.md"
        }
      ]
    },
    {
      "criterionId": "narrow-derived-scopes",
      "description": "Каждая выявленная задача получила один или несколько узких path:<glob>, выведенных из её typed links, существующих каталогов и обязательных generated outputs; path:** не используется.",
      "state": "Passed",
      "evidence": [
        {
          "kind": "File",
          "path": ".temp/taskboard-t1242-add-path-scopes.ps1"
        }
      ]

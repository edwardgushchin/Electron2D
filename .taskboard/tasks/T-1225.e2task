      "payload": {
        "sourceKind": "TaskPatchedV3Draft",
        "text": "{\"patch\":[{\"op\":\"replace\",\"path\":\"/description\",\"value\":\"\\u0421\\u0435\\u0439\\u0447\\u0430\\u0441 \\u043E\\u0431\\u044B\\u0447\\u043D\\u0430\\u044F \\u043A\\u043D\\u043E\\u043F\\u043A\\u0430 \\u00AB\\u0421\\u043E\\u0437\\u0434\\u0430\\u0442\\u044C \\u0437\\u0430\\u0434\\u0430\\u0447\\u0443\\u00BB \\u0437\\u0430\\u043F\\u0443\\u0441\\u043A\\u0430\\u0435\\u0442 \\u0447\\u0435\\u0442\\u044B\\u0440\\u0435 \\u043F\\u043E\\u0441\\u043B\\u0435\\u0434\\u043E\\u0432\\u0430\\u0442\\u0435\\u043B\\u044C\\u043D\\u044B\\u0445 \\u0060window.prompt\\u0060 \\u0434\\u043B\\u044F \\u043D\\u0430\\u0437\\u0432\\u0430\\u043D\\u0438\\u044F, \\u043E\\u043F\\u0438\\u0441\\u0430\\u043D\\u0438\\u044F, \\u043F\\u0440\\u0438\\u043E\\u0440\\u0438\\u0442\\u0435\\u0442\\u0430 \\u0438 \\u0441\\u0440\\u043E\\u043A\\u0430. \\u0412\\u043C\\u0435\\u0441\\u0442\\u043E \\u044D\\u0442\\u043E\\u0433\\u043E \\u043F\\u043E \\u043D\\u0430\\u0436\\u0430\\u0442\\u0438\\u044E \\u0434\\u043E\\u043B\\u0436\\u043D\\u043E \\u043E\\u0442\\u043A\\u0440\\u044B\\u0432\\u0430\\u0442\\u044C\\u0441\\u044F \\u043E\\u0434\\u043D\\u043E \\u043C\\u043E\\u0434\\u0430\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043E\\u043A\\u043D\\u043E \\u0432\\u043D\\u0443\\u0442\\u0440\\u0438 VS Code Task Board. \\u0412 \\u043D\\u0451\\u043C \\u043F\\u043E\\u043B\\u044C\\u0437\\u043E\\u0432\\u0430\\u0442\\u0435\\u043B\\u044C \\u0432\\u0432\\u043E\\u0434\\u0438\\u0442 \\u043E\\u0431\\u044F\\u0437\\u0430\\u0442\\u0435\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043D\\u0430\\u0437\\u0432\\u0430\\u043D\\u0438\\u0435, \\u043C\\u043D\\u043E\\u0433\\u043E\\u0441\\u0442\\u0440\\u043E\\u0447\\u043D\\u043E\\u0435 \\u043E\\u043F\\u0438\\u0441\\u0430\\u043D\\u0438\\u0435 \\u0432 Markdown, \\u0432\\u044B\\u0431\\u0438\\u0440\\u0430\\u0435\\u0442 \\u043F\\u0440\\u0438\\u043E\\u0440\\u0438\\u0442\\u0435\\u0442 \\u0441 \\u043D\\u0430\\u0447\\u0430\\u043B\\u044C\\u043D\\u044B\\u043C \\u0437\\u043D\\u0430\\u0447\\u0435\\u043D\\u0438\\u0435\\u043C \\u0060P2\\u0060 \\u0438 \\u043F\\u0440\\u0438 \\u043D\\u0435\\u043E\\u0431\\u0445\\u043E\\u0434\\u0438\\u043C\\u043E\\u0441\\u0442\\u0438 \\u0437\\u0430\\u0434\\u0430\\u0451\\u0442 \\u0441\\u0440\\u043E\\u043A. \\u041A\\u043D\\u043E\\u043F\\u043A\\u0438 \\u00AB\\u0421\\u043E\\u0437\\u0434\\u0430\\u0442\\u044C\\u00BB \\u0438 \\u00AB\\u041E\\u0442\\u043C\\u0435\\u043D\\u0430\\u00BB, \\u0437\\u0430\\u043A\\u0440\\u044B\\u0442\\u0438\\u0435, backdrop, \\u0060Escape\\u0060 \\u0438 \\u0441\\u043E\\u0447\\u0435\\u0442\\u0430\\u043D\\u0438\\u0435 \\u0060Ctrl\\u002BEnter\\u0060 \\u0434\\u043E\\u043B\\u0436\\u043D\\u044B \\u0440\\u0430\\u0431\\u043E\\u0442\\u0430\\u0442\\u044C \\u043F\\u0440\\u0435\\u0434\\u0441\\u043A\\u0430\\u0437\\u0443\\u0435\\u043C\\u043E \\u0438 \\u0441 \\u043A\\u043B\\u0430\\u0432\\u0438\\u0430\\u0442\\u0443\\u0440\\u044B. \\u0414\\u043E \\u043F\\u043E\\u0434\\u0442\\u0432\\u0435\\u0440\\u0436\\u0434\\u0435\\u043D\\u0438\\u044F \\u043D\\u0438\\u043A\\u0430\\u043A\\u043E\\u0439 taskboard mutation \\u043D\\u0435 \\u0432\\u044B\\u043F\\u043E\\u043B\\u043D\\u044F\\u0435\\u0442\\u0441\\u044F. \\u041F\\u043E\\u0441\\u043B\\u0435 \\u043E\\u0442\\u043F\\u0440\\u0430\\u0432\\u043A\\u0438 \\u0444\\u043E\\u0440\\u043C\\u0430 \\u043F\\u043E\\u043A\\u0430\\u0437\\u044B\\u0432\\u0430\\u0435\\u0442 \\u0441\\u043E\\u0441\\u0442\\u043E\\u044F\\u043D\\u0438\\u0435 \\u0432\\u044B\\u043F\\u043E\\u043B\\u043D\\u0435\\u043D\\u0438\\u044F \\u0438 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0432\\u0430\\u0435\\u0442\\u0441\\u044F \\u0442\\u043E\\u043B\\u044C\\u043A\\u043E \\u043F\\u043E\\u0441\\u043B\\u0435 \\u0443\\u0441\\u043F\\u0435\\u0448\\u043D\\u043E\\u0433\\u043E \\u043E\\u0442\\u0432\\u0435\\u0442\\u0430 Extension Host; \\u043F\\u0440\\u0438 \\u043E\\u0448\\u0438\\u0431\\u043A\\u0435 \\u0432\\u0432\\u0435\\u0434\\u0451\\u043D\\u043D\\u044B\\u0439 \\u0442\\u0435\\u043A\\u0441\\u0442 \\u043E\\u0441\\u0442\\u0430\\u0451\\u0442\\u0441\\u044F \\u043D\\u0430 \\u043C\\u0435\\u0441\\u0442\\u0435, \\u0447\\u0442\\u043E\\u0431\\u044B \\u043F\\u043E\\u043B\\u044C\\u0437\\u043E\\u0432\\u0430\\u0442\\u0435\\u043B\\u044C \\u043C\\u043E\\u0433 \\u0438\\u0441\\u043F\\u0440\\u0430\\u0432\\u0438\\u0442\\u044C \\u0434\\u0430\\u043D\\u043D\\u044B\\u0435 \\u0438\\u043B\\u0438 \\u043F\\u043E\\u0432\\u0442\\u043E\\u0440\\u0438\\u0442\\u044C \\u043F\\u043E\\u043F\\u044B\\u0442\\u043A\\u0443. \\u0421\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u0435 \\u043F\\u043E-\\u043F\\u0440\\u0435\\u0436\\u043D\\u0435\\u043C\\u0443 \\u043F\\u0440\\u043E\\u0445\\u043E\\u0434\\u0438\\u0442 \\u0447\\u0435\\u0440\\u0435\\u0437 allowlisted \\u0441\\u043E\\u043E\\u0431\\u0449\\u0435\\u043D\\u0438\\u0435 Extension Host \\u0438 \\u043F\\u0443\\u0431\\u043B\\u0438\\u0447\\u043D\\u0443\\u044E \\u043A\\u043E\\u043C\\u0430\\u043D\\u0434\\u0443 \\u0060e2d tasks create\\u0060; webview \\u043D\\u0435 \\u043F\\u0438\\u0448\\u0435\\u0442 \\u0060.taskboard\\u0060 \\u043D\\u0430\\u043F\\u0440\\u044F\\u043C\\u0443\\u044E.\"},{\"op\":\"replace\",\"path\":\"/executionContract\",\"value\":{\"taskType\":\"\\u043C\\u043E\\u0434\\u0430\\u043B\\u044C\\u043D\\u0430\\u044F \\u0444\\u043E\\u0440\\u043C\\u0430 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u044F \\u0437\\u0430\\u0434\\u0430\\u0447\\u0438 \\u0432 VS Code Task Board\",\"readyToStart\":[\"\\u0060docs/editor/project-tasks-board.md\\u0060 \\u0434\\u043E production-\\u043A\\u043E\\u0434\\u0430 \\u043E\\u043F\\u0440\\u0435\\u0434\\u0435\\u043B\\u044F\\u0435\\u0442 \\u043F\\u043E\\u043B\\u044F \\u0444\\u043E\\u0440\\u043C\\u044B, lifecycle \\u0447\\u0435\\u0440\\u043D\\u043E\\u0432\\u0438\\u043A\\u0430, validation, pending/success/error, keyboard \\u0438 focus behavior.\",\"\\u0421\\u0443\\u0449\\u0435\\u0441\\u0442\\u0432\\u0443\\u044E\\u0449\\u0438\\u0439 create route \\u043F\\u043E\\u0434\\u0442\\u0432\\u0435\\u0440\\u0436\\u0434\\u0451\\u043D: webview \\u043E\\u0442\\u043F\\u0440\\u0430\\u0432\\u043B\\u044F\\u0435\\u0442 title/description/priority/deadline, Extension Host \\u0432\\u044B\\u043F\\u043E\\u043B\\u043D\\u044F\\u0435\\u0442 \\u043F\\u0443\\u0431\\u043B\\u0438\\u0447\\u043D\\u044B\\u0439 \\u0060e2d tasks create\\u0060; schema \\u0438 lifecycle \\u0437\\u0430\\u0434\\u0430\\u0447\\u0438 \\u043D\\u0435 \\u0440\\u0430\\u0441\\u0448\\u0438\\u0440\\u044F\\u044E\\u0442\\u0441\\u044F.\",\"\\u0414\\u043E \\u0440\\u0435\\u0430\\u043B\\u0438\\u0437\\u0430\\u0446\\u0438\\u0438 \\u0434\\u043E\\u0431\\u0430\\u0432\\u043B\\u0435\\u043D\\u044B \\u043F\\u0430\\u0434\\u0430\\u044E\\u0449\\u0438\\u0435 tests \\u0434\\u043B\\u044F DOM-\\u0444\\u043E\\u0440\\u043C\\u044B, \\u0435\\u0434\\u0438\\u043D\\u0441\\u0442\\u0432\\u0435\\u043D\\u043D\\u043E\\u0439 \\u043A\\u043D\\u043E\\u043F\\u043A\\u0438 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u044F, submit acknowledgement, error retention, localization, security parser \\u0438 responsive layout.\"],\"stopConditions\":[\"\\u0420\\u0435\\u0430\\u043B\\u0438\\u0437\\u0430\\u0446\\u0438\\u044F \\u0442\\u0440\\u0435\\u0431\\u0443\\u0435\\u0442 \\u043F\\u0440\\u044F\\u043C\\u043E\\u0433\\u043E \\u0440\\u0435\\u0434\\u0430\\u043A\\u0442\\u0438\\u0440\\u043E\\u0432\\u0430\\u043D\\u0438\\u044F \\u0060.taskboard\\u0060, \\u043E\\u0431\\u0445\\u043E\\u0434\\u0430 Extension Host allowlist \\u043B\\u0438\\u0431\\u043E \\u0438\\u0437\\u043C\\u0435\\u043D\\u0435\\u043D\\u0438\\u044F TaskBoard schema/lifecycle.\",\"\\u0424\\u043E\\u0440\\u043C\\u0430 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0432\\u0430\\u0435\\u0442\\u0441\\u044F \\u0434\\u043E \\u0438\\u0437\\u0432\\u0435\\u0441\\u0442\\u043D\\u043E\\u0433\\u043E \\u0440\\u0435\\u0437\\u0443\\u043B\\u044C\\u0442\\u0430\\u0442\\u0430 \\u0438 \\u0442\\u0435\\u0440\\u044F\\u0435\\u0442 \\u043F\\u043E\\u043B\\u044C\\u0437\\u043E\\u0432\\u0430\\u0442\\u0435\\u043B\\u044C\\u0441\\u043A\\u0438\\u0439 \\u0442\\u0435\\u043A\\u0441\\u0442 \\u043F\\u0440\\u0438 CLI/schema/revision \\u043E\\u0448\\u0438\\u0431\\u043A\\u0435.\",\"\\u0414\\u043B\\u044F \\u0432\\u0432\\u043E\\u0434\\u0430 \\u043E\\u0441\\u0442\\u0430\\u044E\\u0442\\u0441\\u044F \\u0060window.prompt\\u0060, \\u043D\\u0435\\u0431\\u0435\\u0437\\u043E\\u043F\\u0430\\u0441\\u043D\\u044B\\u0439 HTML \\u0438\\u043B\\u0438 \\u043D\\u0435\\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u0435\\u043D\\u043D\\u043E\\u0435 \\u0441\\u043E\\u043E\\u0431\\u0449\\u0435\\u043D\\u0438\\u0435 \\u0438\\u0437 webview.\",\"\\u041C\\u043E\\u0434\\u0430\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043E\\u043A\\u043D\\u043E \\u043D\\u0435\\u043B\\u044C\\u0437\\u044F \\u0441\\u0434\\u0435\\u043B\\u0430\\u0442\\u044C keyboard-accessible \\u0438 \\u0430\\u0434\\u0430\\u043F\\u0442\\u0438\\u0432\\u043D\\u044B\\u043C \\u0431\\u0435\\u0437 \\u043D\\u0430\\u0440\\u0443\\u0448\\u0435\\u043D\\u0438\\u044F Task Details, toolbar \\u0438\\u043B\\u0438 \\u0433\\u0435\\u043E\\u043C\\u0435\\u0442\\u0440\\u0438\\u0438 \\u043E\\u0431\\u044B\\u0447\\u043D\\u043E\\u0439 \\u043A\\u043D\\u043E\\u043F\\u043A\\u0438 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u044F.\"],\"allowedChanges\":[\"\\u0414\\u043E\\u043C\\u0435\\u043D\\u043D\\u044B\\u0439 \\u0434\\u043E\\u043A\\u0443\\u043C\\u0435\\u043D\\u0442, webview/HTML/CSS/localization/security/Extension Host VS Code Task Board \\u0438 \\u0441\\u0432\\u044F\\u0437\\u0430\\u043D\\u043D\\u044B\\u0435 unit/Extension Host tests.\",\"Generated docs index, \\u0443\\u0441\\u0442\\u0430\\u043D\\u0430\\u0432\\u043B\\u0438\\u0432\\u0430\\u0435\\u043C\\u044B\\u0439 VSIX, task activity, \\u043B\\u043E\\u043A\\u0430\\u043B\\u044C\\u043D\\u044B\\u0435 FFmpeg-\\u0430\\u0440\\u0442\\u0435\\u0444\\u0430\\u043A\\u0442\\u044B \\u0438 append-only \\u0434\\u043D\\u0435\\u0432\\u043D\\u0438\\u043A.\"],\"forbiddenChanges\":[\"\\u0418\\u0437\\u043C\\u0435\\u043D\\u0435\\u043D\\u0438\\u0435 CLI create semantics, TaskBoard schema, default task status/acceptance, board placement \\u0438\\u043B\\u0438 \\u043F\\u0440\\u044F\\u043C\\u043E\\u0439 writer \
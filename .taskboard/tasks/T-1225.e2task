        "text": "{\"patch\":[{\"op\":\"replace\",\"path\":\"/acceptanceCriteria\",\"value\":[{\"criterionId\":\"criterion-create-form-open\",\"description\":\"\\u041D\\u0430\\u0436\\u0430\\u0442\\u0438\\u0435 \\u043E\\u0431\\u044B\\u0447\\u043D\\u043E\\u0439 \\u043A\\u043D\\u043E\\u043F\\u043A\\u0438 \\u00AB\\u0421\\u043E\\u0437\\u0434\\u0430\\u0442\\u044C \\u0437\\u0430\\u0434\\u0430\\u0447\\u0443\\u00BB \\u043E\\u0442\\u043A\\u0440\\u044B\\u0432\\u0430\\u0435\\u0442 \\u043C\\u043E\\u0434\\u0430\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043E\\u043A\\u043D\\u043E. \\u041F\\u043E\\u0441\\u043B\\u0435\\u0434\\u043E\\u0432\\u0430\\u0442\\u0435\\u043B\\u044C\\u043D\\u044B\\u0435 \\u0060window.prompt\\u0060 \\u043F\\u043E\\u043B\\u043D\\u043E\\u0441\\u0442\\u044C\\u044E \\u0443\\u0434\\u0430\\u043B\\u0435\\u043D\\u044B; \\u0443\\u0434\\u0430\\u043B\\u0451\\u043D\\u043D\\u044B\\u0435 \\u0440\\u0430\\u043D\\u0435\\u0435 split-\\u0441\\u0435\\u043A\\u0446\\u0438\\u044F, \\u0441\\u0442\\u0440\\u0435\\u043B\\u043A\\u0430 \\u0438 \\u0434\\u043E\\u043F\\u043E\\u043B\\u043D\\u0438\\u0442\\u0435\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043C\\u0435\\u043D\\u044E \\u043D\\u0435 \\u0432\\u043E\\u0437\\u0432\\u0440\\u0430\\u0449\\u0430\\u044E\\u0442\\u0441\\u044F.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"criterion-create-form-fields\",\"description\":\"\\u0424\\u043E\\u0440\\u043C\\u0430 \\u0441\\u043E\\u0434\\u0435\\u0440\\u0436\\u0438\\u0442 \\u043E\\u0431\\u044F\\u0437\\u0430\\u0442\\u0435\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043E\\u0434\\u043D\\u043E\\u0441\\u0442\\u0440\\u043E\\u0447\\u043D\\u043E\\u0435 \\u043D\\u0430\\u0437\\u0432\\u0430\\u043D\\u0438\\u0435, \\u043C\\u043D\\u043E\\u0433\\u043E\\u0441\\u0442\\u0440\\u043E\\u0447\\u043D\\u043E\\u0435 \\u043E\\u043F\\u0438\\u0441\\u0430\\u043D\\u0438\\u0435 Markdown, \\u0432\\u044B\\u0431\\u043E\\u0440 \\u0060P0\\u0060\\u2013\\u0060P3\\u0060 \\u0441 \\u043D\\u0430\\u0447\\u0430\\u043B\\u044C\\u043D\\u044B\\u043C \\u0060P2\\u0060 \\u0438 \\u043D\\u0435\\u043E\\u0431\\u044F\\u0437\\u0430\\u0442\\u0435\\u043B\\u044C\\u043D\\u044B\\u0439 \\u0441\\u0440\\u043E\\u043A \\u0432 \\u0444\\u043E\\u0440\\u043C\\u0430\\u0442\\u0435 \\u0434\\u0430\\u0442\\u044B. \\u00AB\\u0421\\u043E\\u0437\\u0434\\u0430\\u0442\\u044C\\u00BB \\u043D\\u0435\\u0434\\u043E\\u0441\\u0442\\u0443\\u043F\\u043D\\u0430 \\u0434\\u043B\\u044F \\u043F\\u0443\\u0441\\u0442\\u043E\\u0433\\u043E \\u043D\\u0430\\u0437\\u0432\\u0430\\u043D\\u0438\\u044F; \\u043F\\u0440\\u043E\\u0431\\u0435\\u043B\\u044B \\u043D\\u043E\\u0440\\u043C\\u0430\\u043B\\u0438\\u0437\\u0443\\u044E\\u0442\\u0441\\u044F, \\u043D\\u0435\\u043A\\u043E\\u0440\\u0440\\u0435\\u043A\\u0442\\u043D\\u044B\\u0439 \\u0441\\u0440\\u043E\\u043A \\u043F\\u043E\\u043A\\u0430\\u0437\\u044B\\u0432\\u0430\\u0435\\u0442\\u0441\\u044F \\u0440\\u044F\\u0434\\u043E\\u043C \\u0441 \\u043F\\u043E\\u043B\\u0435\\u043C, \\u043D\\u0435 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0432\\u0430\\u044F \\u043E\\u043A\\u043D\\u043E.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"criterion-create-form-submit\",\"description\":\"\\u041F\\u043E\\u0434\\u0442\\u0432\\u0435\\u0440\\u0436\\u0434\\u0435\\u043D\\u0438\\u0435 \\u043A\\u043D\\u043E\\u043F\\u043A\\u043E\\u0439 \\u0438\\u043B\\u0438 \\u0060Ctrl\\u002BEnter\\u0060 \\u043E\\u0442\\u043F\\u0440\\u0430\\u0432\\u043B\\u044F\\u0435\\u0442 \\u0440\\u043E\\u0432\\u043D\\u043E \\u043E\\u0434\\u043D\\u043E allowlisted \\u0441\\u043E\\u043E\\u0431\\u0449\\u0435\\u043D\\u0438\\u0435 \\u0438 \\u0431\\u043B\\u043E\\u043A\\u0438\\u0440\\u0443\\u0435\\u0442 \\u043F\\u043E\\u0432\\u0442\\u043E\\u0440\\u043D\\u0443\\u044E \\u043E\\u0442\\u043F\\u0440\\u0430\\u0432\\u043A\\u0443 \\u0434\\u043E \\u043E\\u0442\\u0432\\u0435\\u0442\\u0430. \\u0423\\u0441\\u043F\\u0435\\u0445 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0432\\u0430\\u0435\\u0442 \\u0444\\u043E\\u0440\\u043C\\u0443, \\u043E\\u0447\\u0438\\u0449\\u0430\\u0435\\u0442 \\u0447\\u0435\\u0440\\u043D\\u043E\\u0432\\u0438\\u043A \\u0438 \\u043E\\u0431\\u043D\\u043E\\u0432\\u043B\\u044F\\u0435\\u0442 canonical board; \\u043E\\u0448\\u0438\\u0431\\u043A\\u0430 \\u0441\\u043D\\u0438\\u043C\\u0430\\u0435\\u0442 pending-state, \\u0441\\u043E\\u0445\\u0440\\u0430\\u043D\\u044F\\u0435\\u0442 \\u0432\\u0441\\u0435 \\u0432\\u0432\\u0435\\u0434\\u0451\\u043D\\u043D\\u044B\\u0435 \\u0437\\u043D\\u0430\\u0447\\u0435\\u043D\\u0438\\u044F \\u0438 \\u043F\\u043E\\u043A\\u0430\\u0437\\u044B\\u0432\\u0430\\u0435\\u0442 \\u043F\\u043E\\u043D\\u044F\\u0442\\u043D\\u0443\\u044E \\u0434\\u0438\\u0430\\u0433\\u043D\\u043E\\u0441\\u0442\\u0438\\u043A\\u0443 \\u0431\\u0435\\u0437 optimistic task card.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"criterion-create-form-cancel\",\"description\":\"\\u00AB\\u041E\\u0442\\u043C\\u0435\\u043D\\u0430\\u00BB, \\u043A\\u043D\\u043E\\u043F\\u043A\\u0430 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0442\\u0438\\u044F, backdrop \\u0438 \\u0060Escape\\u0060 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0432\\u0430\\u044E\\u0442 \\u0444\\u043E\\u0440\\u043C\\u0443 \\u0431\\u0435\\u0437 CLI-\\u0432\\u044B\\u0437\\u043E\\u0432\\u0430 \\u0438 \\u0432\\u043E\\u0437\\u0432\\u0440\\u0430\\u0449\\u0430\\u044E\\u0442 focus \\u0438\\u0441\\u0445\\u043E\\u0434\\u043D\\u043E\\u0439 \\u043A\\u043D\\u043E\\u043F\\u043A\\u0435. \\u0412\\u043E \\u0432\\u0440\\u0435\\u043C\\u044F pending-state \\u0441\\u043B\\u0443\\u0447\\u0430\\u0439\\u043D\\u043E\\u0435 \\u0437\\u0430\\u043A\\u0440\\u044B\\u0442\\u0438\\u0435 \\u043D\\u0435 \\u043F\\u0440\\u0438\\u0432\\u043E\\u0434\\u0438\\u0442 \\u043A \\u043D\\u0435\\u0438\\u0437\\u0432\\u0435\\u0441\\u0442\\u043D\\u043E\\u043C\\u0443 \\u0440\\u0435\\u0437\\u0443\\u043B\\u044C\\u0442\\u0430\\u0442\\u0443 \\u0438\\u043B\\u0438 \\u043F\\u043E\\u0432\\u0442\\u043E\\u0440\\u043D\\u043E\\u043C\\u0443 \\u0441\\u043E\\u0437\\u0434\\u0430\\u043D\\u0438\\u044E; \\u043F\\u043E\\u0441\\u043B\\u0435 \\u044F\\u0432\\u043D\\u043E\\u0439 \\u043E\\u0442\\u043C\\u0435\\u043D\\u044B \\u043D\\u043E\\u0432\\u044B\\u0439 \\u0441\\u0435\\u0430\\u043D\\u0441 \\u043D\\u0430\\u0447\\u0438\\u043D\\u0430\\u0435\\u0442\\u0441\\u044F \\u0441 \\u043F\\u0443\\u0441\\u0442\\u043E\\u0433\\u043E \\u0447\\u0435\\u0440\\u043D\\u043E\\u0432\\u0438\\u043A\\u0430 \\u0438 \\u043F\\u0440\\u0438\\u043E\\u0440\\u0438\\u0442\\u0435\\u0442\\u0430 \\u0060P2\\u0060.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"criterion-create-form-accessibility\",\"description\":\"\\u041E\\u043A\\u043D\\u043E \\u0438\\u043C\\u0435\\u0435\\u0442 \\u043A\\u043E\\u0440\\u0440\\u0435\\u043A\\u0442\\u043D\\u044B\\u0435 \\u0060role=dialog\\u0060, \\u0060aria-modal\\u0060, \\u0441\\u0432\\u044F\\u0437\\u0430\\u043D\\u043D\\u044B\\u0439 \\u0437\\u0430\\u0433\\u043E\\u043B\\u043E\\u0432\\u043E\\u043A, \\u0432\\u0438\\u0434\\u0438\\u043C\\u044B\\u0435 labels, \\u0443\\u043F\\u0440\\u0430\\u0432\\u043B\\u044F\\u0435\\u043C\\u044B\\u0439 focus \\u0438 \\u043B\\u043E\\u0433\\u0438\\u0447\\u043D\\u044B\\u0439 tab order. \\u0420\\u0443\\u0441\\u0441\\u043A\\u0430\\u044F \\u0438 \\u0430\\u043D\\u0433\\u043B\\u0438\\u0439\\u0441\\u043A\\u0430\\u044F \\u043B\\u043E\\u043A\\u0430\\u043B\\u0438\\u0437\\u0430\\u0446\\u0438\\u0438 \\u043F\\u043E\\u043B\\u043D\\u044B; \\u0440\\u0430\\u0437\\u043C\\u0435\\u0440\\u044B, \\u043F\\u0440\\u043E\\u043A\\u0440\\u0443\\u0442\\u043A\\u0430, \\u043E\\u0448\\u0438\\u0431\\u043A\\u0438, focus/hover \\u0438 disabled-state \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u044E\\u0442 \\u0442\\u0435\\u043C\\u0443 VS Code \\u0438 \\u043D\\u0435 \\u0432\\u044B\\u0445\\u043E\\u0434\\u044F\\u0442 \\u0437\\u0430 viewport \\u043D\\u0430 \\u0443\\u0437\\u043A\\u043E\\u0439 \\u0448\\u0438\\u0440\\u0438\\u043D\\u0435.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"criterion-create-form-boundary\",\"description\":\"Webview \\u043F\\u0435\\u0440\\u0435\\u0434\\u0430\\u0451\\u0442 \\u0442\\u043E\\u043B\\u044C\\u043A\\u043E \\u043F\\u0440\\u043E\\u0432\\u0435\\u0440\\u0435\\u043D\\u043D\\u044B\\u0435 title, description, priority \\u0438 optional deadline; Extension Host \\u0438\\u0441\\u043F\\u043E\\u043B\\u044C\\u0437\\u0443\\u0435\\u0442 \\u043F\\u0443\\u0431\\u043B\\u0438\\u0447\\u043D\\u044B\\u0439 \\u0060e2d tasks create\\u0060, \\u0430 \\u043F\\u0440\\u044F\\u043C\\u043E\\u0439 \\u0437\\u0430\\u043F\\u0438\\u0441\\u0438 \\u0060.taskboard\\u0060 \\u043D\\u0435\\u0442. \\u0422\\u0435\\u043A\\u0441\\u0442 \\u0432\\u0441\\u0442\\u0430\\u0432\\u043B\\u044F\\u0435\\u0442\\u0441\\u044F \\u0442\\u043E\\u043B\\u044C\\u043A\\u043E \\u043A\\u0430\\u043A value/textContent, \\u043D\\u0435 \\u0438\\u043D\\u0442\\u0435\\u0440\\u043F\\u0440\\u0435\\u0442\\u0438\\u0440\\u0443\\u0435\\u0442\\u0441\\u044F \\u043A\\u0430\\u043A HTML \\u0438 \\u0441\\u043E\\u0445\\u0440\\u0430\\u043D\\u044F\\u0435\\u0442\\u0441\\u044F \\u0434\\u043E\\u0441\\u043B\\u043E\\u0432\\u043D\\u043E \\u043F\\u043E\\u0441\\u043B\\u0435 schema/security validation.\",\"state\":\"Open\",\"evidence\":[]},{\"criterionId\":\"criterion-create-form-verification\",\"description\":\"\\u0414\\u043E\\u043C\\u0435\\u043D\\u043D\\u044B\\u0439 \\u0434\\u043E\\u043A\\u0443\\u043C\\u0435\\u043D\\u0442 \\u043E\\u0431\\u043D\\u043E\\u0432\\u043B\\u0451\\u043D \\u0434\\u043E production-\\u043A\\u043E\\u0434\\u0430; RED/GREEN tests \\u043F\\u043E\\u043A\\u0440\\u044B\\u0432\\u0430\\u044E\\u0442 \\u043E\\u0442\\u043A\\u0440\\u044B\\u0442\\u0438\\u0435 \\u043E\\u0431\\u043E\\u0438\\u043C\\u0438 triggers, validation, keyboard/focus, cancel, pending/success/error \\u0438 security parser. \\u041F\\u043E\\u043B\\u043D\\u044B\\u0439 unit-\\u043D\\u0430\\u0431\\u043E\\u0440, typecheck, Extension Host tests, VSIX \\u0438 FFmpeg-\\u0441\\u043D\\u0438\\u043C\\u043E\\u043A \\u0443\\u0441\\u0442\\u0430\\u043D\\u043E\\u0432\\u043B\\u0435\\u043D\\u043D\\u043E\\u0433\\u043E \\u0440\\u0430\\u0441\\u0448\\u0438\\u0440\\u0435\\u043D\\u0438\\u044F \\u043F\\u043E\\u0434\\u0442\\u0432\\u0435\\u0440\\u0436\\u0434\\u0430\\u044E\\u0442 \\u0440\\u0435\\u0430\\u043B\\u044C\\u043D\\u043E\\u0435 \\u043E\\u043A\\u043D\\u043E \\u0441 \\u0437\\u0430\\u043F\\u043E\\u043B\\u043D\\u0435\\u043D\\u043D\\u043E\\u0439 \\u043C\\u043D\\u043E\\u0433\\u043E\\u0441\\u0442\\u0440\\u043E\\u0447\\u043D\\u043E\\u0439 \\u0444\\u043E\\u0440\\u043C\\u043E\\u0439 \\u0431\\u0435\\u0437 overflow.\",\"state\":\"Open\",\"evidence\":[]}]}],\"beforeTaskCoreDigest\":\"a2efc1b6de13a84e274fcbb8ba88aa288a66e1ab831f0b73abd47c6941134384\",\"afterTaskCoreDigest\":\"6827ee1f2afca58799e3d52b4984cd4ec34bb988c834a64a784bc6b7fa03ff69\"}"

      "returnType": "Texture2D",
      "parameters": [],
      "summary": "The sky cover texture to use. This texture must use an equirectangular projection (similar to [PanoramaSkyMaterial]). The texture\u0027s colors will be [i]added[/i] to the existing sky color, and will be multiplied by [member sky_energy_multiplier] and [member sky_cover_modulate]. This is mainly suited to displaying stars at night, but it can also be used to display clouds at day or night (with a non-physically-accurate look).",
      "godotName": "sky_cover",
      "xmlDocId": "P:Godot.ProceduralSkyMaterial.SkyCover",
      "sourcePath": "doc/classes/ProceduralSkyMaterial.xml"

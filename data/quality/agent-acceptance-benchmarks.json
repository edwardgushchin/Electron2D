    {
      "id": "headless-ai",
      "title": "Headless AI acceptance benchmark",
      "mode": "headless",
      "releaseRequired": true,
      "targetSuccessRatio": 0.8,
      "documentation": [
        "docs/testing/agent-acceptance-benchmarks.md",
        "docs/testing/agent-acceptance-benchmarks.md",
        "docs/project-system/static-context-pack.md",
        "docs/runtime/headless-runtime-automation.md"
      ],
      "scenarios": [
        { "id": "headless-installed-engine", "title": "Agent works from installed Electron2D, docs, CLI and MCP without engine source as input." },
        { "id": "headless-five-tasks", "title": "Benchmark contains five reference tasks." },
        { "id": "headless-no-generated-cache-edits", "title": "Generated cache and local session folders are forbidden." },
        { "id": "headless-no-unsupported-api", "title": "Unsupported API usage fails the benchmark." },
        { "id": "headless-two-agent-or-manual-harness", "title": "Two-agent run or documented manual harness exists until automation." }
      ],
      "headlessTasks": [
        { "id": "create-project", "title": "Create a new Electron2D project." },
        { "id": "change-scene", "title": "Modify a scene through CLI/MCP and keep project text valid." },
        { "id": "implement-mechanic", "title": "Implement a small C# gameplay mechanic in the user project." },
        { "id": "fix-diagnostic", "title": "Fix a structured diagnostic without hidden instructions." },
        { "id": "verify-and-build", "title": "Run checks and build/export the project." }
      ],

{
  "format": "Electron2D.AgentAcceptanceBenchmarkManifest",
  "version": 1,
  "release": "0.1.0-preview",
  "suites": [
    {
      "id": "editor-co-development",
      "title": "Editor co-development acceptance benchmark",
      "mode": "activeEditor",
      "releaseRequired": true,
      "targetSuccessRatio": 1.0,
      "documentation": [
        "docs/testing/agent-acceptance-benchmarks.md",
        "docs/testing/agent-acceptance-benchmarks.md",
        "docs/editor/godot4-editor-reference.md"
      ],
      "scenarios": [
        { "id": "active-editor-route", "title": "CLI and MCP route mutating commands into the active Editor workspace." },
        { "id": "created-script-visible", "title": "Created C# script files are visible in Editor workspaces without manual refresh." },
        { "id": "scene-inspector-viewport-update", "title": "Scene changes update Scene Tree, Inspector and viewport evidence." },
        { "id": "concurrent-editing-conflict-panel", "title": "Concurrent edits merge safely or surface a conflict instead of losing data." },
        { "id": "visible-runtime-control", "title": "Visible runtime can run, pause, step, receive input and expose screenshot/tree/diagnostics." },
        { "id": "snapshot-artifact-stale-policy", "title": "Run/build/test artifacts carry snapshot identity and stale only on game inputs." },
        { "id": "task-metadata-not-stale", "title": "Task metadata edits do not stale game artifacts." },
        { "id": "project-task-manager-links", "title": "Active task links transactions, jobs, diagnostics and artifacts." },
        { "id": "agent-awaiting-acceptance-only", "title": "Agent can submit for acceptance but cannot mark the task Done." },
        { "id": "trusted-human-acceptance", "title": "Human acceptance uses trusted interactive Editor context only." },
        { "id": "project-tasks-board-manual-flow", "title": "Project Tasks board supports manual create/select/accept/request-changes flow." },
        { "id": "script-workspace-tooling", "title": "Script workspace exposes Tooling/MCP text edits, diagnostics and completion." },
        { "id": "editor-window-screenshot-analysis", "title": "Real Editor window screenshot and analysis prove visible UI layout quality." },
        { "id": "managed-debugger-tooling", "title": "Managed debugger commands expose breakpoints, stacks, frame variables and watches." },
        { "id": "structured-diagnostics-ai-fix", "title": "Structured diagnostics are available as benchmark evidence for AI fixes." },
        { "id": "grouped-ai-undo", "title": "AI transaction can be undone as one group." },
        { "id": "agent-crash-read-and-staged-transaction", "title": "Agent disconnect/crash and failed staged changes release leases and preserve workspace integrity." },
        { "id": "editor-without-mcp", "title": "Editor manual workflow works without an active MCP session." }
      ],
      "evidence": [
        {
          "id": "editor-real-window-smoke",

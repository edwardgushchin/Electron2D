  "acceptanceCriteria": [
    {
      "criterionId": "t-0223-criterion-01",
      "description": "До изменения verifier-а `docs/examples/platformer.md` описывает acceptance sequence и запрещённые прямые мутации игрового состояния.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-02",
      "description": "Добавлены сначала падающие tests, которые ловят текущие ложноположительные `Playable=True`, `CharacterMoved` и прямую выдачу coins/checkpoint/save.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-03",
      "description": "`Playable=True` требует наблюдаемую последовательность `runtime launch -> InputMap events -> movement -> jump -> landing on one-way platform -> coin pickup -> checkpoint activation -> death -> respawn -> process shutdown -> process relaunch -> save restore -> goal`.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-04",
      "description": "Verifier не вызывает игровые методы так, чтобы обходить collision/trigger path, и не присваивает checkpoint, coins, save payload или win state напрямую.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-05",
      "description": "`CharacterMoved` считается истинным только после реального смещения от input/runtime step, а не из-за ненулевой стартовой позиции.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-06",
      "description": "Save verification читает файл, созданный после игрового checkpoint/collectible path, и сравнивает payload с состоянием игры.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-07",
      "description": "Acceptance выполняет и смерть/respawn, и отдельный relaunch процесса с восстановлением сохранения; `death or reload` не допускается как ослабленный вариант.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-08",
      "description": "Acceptance artifact включает machine-readable event trace по ключевым gameplay events, frame index, timestamp и итоговую причину pass/fail.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0223-criterion-09",
      "description": "После зелёных проверок доменный документ фиксирует фактический acceptance contract и команды проверки.",
      "state": "Open",
      "evidence": []
    }
  ],

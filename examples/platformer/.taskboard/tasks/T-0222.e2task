  "acceptanceCriteria": [
    {
      "criterionId": "t-0222-criterion-01",
      "description": "До изменения сцен/кода `docs/examples/platformer.md` переписан как целевая спецификация настоящей игры, а не verifier showcase.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-02",
      "description": "Добавлены сначала падающие tests, которые ловят текущие две клетки `TileMapLayer`, декоративную землю вне collision, ручные coins/checkpoint и отсутствие реальной walk animation.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-03",
      "description": "Уровень рассчитан на 45-90 секунд прохождения и содержит старт, обычные платформы, one-way platforms, разрывы, опасность, checkpoint, collectibles и цель.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-04",
      "description": "Deterministic replay проходит objective path в диапазоне 45-90 секунд и сохраняется как acceptance evidence.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-05",
      "description": "Видимый уровень и collision geometry задаются единым игровым `TileMapLayer` или явно синхронизированной парой данных; декоративные `TextureRect` не расходятся с физикой.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-06",
      "description": "Все world-объекты находятся внутри одного `World`; camera, player, hazards, collectibles, checkpoint и goal используют одно координатное пространство.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-07",
      "description": "Coins являются настоящими collectible objects с collision/trigger behavior; код не присваивает `coins = 1` по координате или из verifier-а.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-08",
      "description": "Checkpoint является настоящим trigger object; сохранение прогресса происходит после игрового взаимодействия, а не через прямой вызов verifier-а.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-09",
      "description": "Есть явные состояния `Playing`, `Paused`, `Dead`, `Won` с документированными переходами.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-10",
      "description": "Есть title/start scene и result/restart flow либо другой реальный scene switch, проверяемый runtime path.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-11",
      "description": "Есть смерть, respawn, restart и детерминированное восстановление checkpoint/coins после reload.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-12",
      "description": "Semantics checkpoint и собранных coins детерминированы: повторный pickup не дублирует coin, checkpoint restore не теряет уже сохранённое состояние.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-13",
      "description": "Есть goal и наблюдаемое win state.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-14",
      "description": "Player имеет разные idle/run/jump/fall frames, корректное переключение animation state и разворот спрайта по направлению.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-15",
      "description": "Animation state transition вызывается только при смене состояния, а не повторно каждый движущийся кадр.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-16",
      "description": "`jump` не двигает персонажа вправо, а остановка движения возвращает animation в `idle`.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-17",
      "description": "Camera имеет limits, dead zone или документированное поведение следования, pixel snapping и не оставляет пустую чёрную половину кадра.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-18",
      "description": "HUD находится только в `CanvasLayer`; pause menu, звук и save/load остаются частью игрового loop.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-19",
      "description": "HUD обновляется только при изменении отображаемого состояния и не создаёт новую строку каждый кадр.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-20",
      "description": "Production gameplay class не содержит `RunHeadlessVerification`, `RunPlayableScript` или аналогичные acceptance-only entrypoints; acceptance hooks вынесены в тестовый/runner слой.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0222-criterion-21",
      "description": "После зелёных проверок доменный документ описывает фактическую игру, ограничения, screenshots и команды проверки.",
      "state": "Open",
      "evidence": []
    }
  ],

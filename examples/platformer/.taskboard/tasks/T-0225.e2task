  "acceptanceCriteria": [
    {
      "criterionId": "t-0225-criterion-01",
      "description": "До изменения verifier-а `docs/examples/platformer.md` и `docs/testing/scene-visual-testing.md` описывают visual gate как отдельный контракт от black-box gameplay acceptance.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-02",
      "description": "Gate создаёт кадры start, checkpoint, death, pause и goal.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-03",
      "description": "Для каждого кадра artifact содержит runtime probes: player bounds, camera transform, viewport size, HUD bounds, current state, frame index и event timestamp.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-04",
      "description": "Pixel analysis проверяет пустые/обрезанные области с учётом runtime probes и не падает только из-за законной тёмной сцены.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-05",
      "description": "Gate ловит рассогласование `World`/camera/HUD, скрытую служебную геометрию, обрезанный уровень и HUD, который движется вместе с камерой.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-06",
      "description": "Gate не засчитывает screenshot, если PNG создан не из scene tree/rendering path актуального `e2d run`.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-07",
      "description": "Focused tests отклоняют специально подготовленные malformed fixtures с рассогласованными `World`/camera/HUD probes, обрезанным viewport и пустым кадром, а актуальные кадры Platformer проходят.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0225-criterion-08",
      "description": "После зелёных проверок artifact paths и команды проверки записаны в доменный документ и дневник.",
      "state": "Open",
      "evidence": []
    }
  ],

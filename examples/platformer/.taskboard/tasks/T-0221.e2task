  "acceptanceCriteria": [
    {
      "criterionId": "t-0221-criterion-01",
      "description": "До изменения кода `docs/quality/performance-verification.md` описывает новый live measurement contract и явно помечает прежний static artifact как недостаточный для текущего аудита.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-02",
      "description": "`T-0215` предоставляет C# performance runner, metrics schema, timeout и structured diagnostics; `T-0221` не создаёт новый PowerShell-only gate поверх будущего C# tooling.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-03",
      "description": "Добавлены сначала падающие tests, которые не дают пройти gate на текущем `RuntimeHost` с per-frame framebuffer allocation и post-render sleep.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-04",
      "description": "C# performance command из `T-0215` запускает свежий measurement run, привязанный к commit/build identity, а не только читает старый JSON.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-05",
      "description": "Обязательный сценарий `Platformer` запускается в Release, 1280x720, с warm-up не меньше 10 секунд и measurement window не меньше 60 секунд.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-06",
      "description": "Artifact фиксирует CPU, GPU, RAM, OS build, graphics driver, power plan, debugger attached = false, window visibility/focus и VSync/frame limiter mode.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-07",
      "description": "Artifact фиксирует Release commit SHA, build identity и точный command line.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-08",
      "description": "Artifact описывает метод измерения allocations и memory counters.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-09",
      "description": "Gate требует `p95FrameTimeMs <= 16.67`, фиксирует `p50`, `p95`, `p99`, `average`, `min`, `max` и итоговый pass/fail.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-10",
      "description": "Gate требует `steadyManagedAllocatedBytesPerFrame = 0` после прогрева и проверяет отсутствие постоянного роста managed memory.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-11",
      "description": "Artifact включает slope managed/private memory, missed-frame count, Gen0/Gen1/Gen2 collections во время measurement window, draw commands, batches, texture switches и time breakdown `input`/`physics`/`process`/`render-plan`/`submit`/`present`.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-12",
      "description": "Artifact содержит пути к screenshot/video/metrics evidence и не засчитывает пустой или визуально рассогласованный кадр.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-13",
      "description": "`T-0093` и `T-0104` не могут быть приняты, если этот gate не прошёл на актуальном Platformer.",
      "state": "Open",
      "evidence": []
    },
    {
      "criterionId": "t-0221-criterion-14",
      "description": "После зелёных проверок доменный документ и artifact обновлены фактическими командами и результатами.",
      "state": "Open",
      "evidence": []
    }
  ],

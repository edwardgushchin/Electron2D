{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electron2d.dev/schemas/project-system/electron2d-lock.schema.json",
  "title": "Electron2D reproducibility lock schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "format",
    "schemaVersion",
    "engine",
    "dotnet",
    "nuget",
    "nativeRuntime",
    "assetImporters",
    "project",
    "exportTemplates",
    "signing"
  ],
  "properties": {
    "$schema": {
      "const": "https://electron2d.dev/schemas/project-system/electron2d-lock.schema.json"
    },
    "format": {
      "const": "Electron2D.ReproducibilityLock"
    },
    "schemaVersion": {
      "const": 1
    },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dotnet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sdkVersion",
        "rollForward",
        "targetFramework"
      ],
      "properties": {
        "sdkVersion": {
          "type": "string",
          "minLength": 1
        },
        "rollForward": {
          "type": "string",
          "minLength": 1
        },
        "targetFramework": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nuget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packages"
      ],
      "properties": {
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/package"
          }
        }
      }
    },
    "nativeRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packages"
      ],
      "properties": {
        "packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/package"
          }
        }
      }
    },
    "assetImporters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "texture",
        "font",
        "audio",
        "shader"
      ],
      "properties": {
        "texture": {
          "type": "string",
          "minLength": 1
        },
        "font": {
          "type": "string",
          "minLength": 1
        },
        "audio": {
          "type": "string",
          "minLength": 1
        },
        "shader": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rendererProfile",
        "physicsBackendVersion",
        "serializationSchemaVersion"
      ],
      "properties": {
        "rendererProfile": {
          "enum": [
            "Automatic",
            "Compatibility",
            "Standard"
          ]
        },
        "physicsBackendVersion": {
          "type": "string",
          "minLength": 1
        },
        "serializationSchemaVersion": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "exportTemplates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version"
      ],
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "signing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "const": "referencesOnly"
        }
      }
    }
  },
  "$defs": {
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
